{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "desktop: build macOS",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "Sufni.App/Sufni.App.macOS/Sufni.App.macOS.csproj",
        "-c",
        "Debug",
        "-f",
        "net10.0-macos"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$msCompile"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "desktop: build Linux",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "Sufni.App/Sufni.App.Linux/Sufni.App.Linux.csproj",
