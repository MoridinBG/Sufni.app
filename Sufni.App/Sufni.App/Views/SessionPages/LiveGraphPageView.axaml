<UserControl
x:Class="Sufni.App.Views.SessionPages.LiveGraphPageView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:plotModels="clr-namespace:Sufni.App.Plots"
xmlns:plots="clr-namespace:Sufni.App.DesktopViews.Plots"
xmlns:v="clr-namespace:Sufni.App.Views"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.SessionPages"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:LiveGraphPageViewModel"
mc:Ignorable="d">

    <ScrollViewer
    x:Name="PageScrollViewer"
    Width="{Binding $parent[ScrollViewer].Bounds.Width}"
    IsScrollChainingEnabled="False">
        <StackPanel Spacing="10">
            <Grid MinHeight="{Binding #PageScrollViewer.Bounds.Height}" x:Name="GraphGrid" Margin="-8,0,-8,0">
                <Grid.Resources>
                    <controls:SurfaceStateToViewportFractionGridLengthConverter x:Key="MobileGraphRowHeightConverter" />
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition>
                        <RowDefinition.Height>
                            <MultiBinding Converter="{StaticResource MobileGraphRowHeightConverter}" ConverterParameter="3">
                                <Binding Path="Workspace.TravelGraphState" />
                                <Binding ElementName="PageScrollViewer" Path="Bounds.Height" />
                            </MultiBinding>
                        </RowDefinition.Height>
                    </RowDefinition>
                    <RowDefinition>
                        <RowDefinition.Height>
                            <MultiBinding Converter="{StaticResource MobileGraphRowHeightConverter}" ConverterParameter="3">
                                <Binding Path="Workspace.VelocityGraphState" />
                                <Binding ElementName="PageScrollViewer" Path="Bounds.Height" />
                            </MultiBinding>
                        </RowDefinition.Height>
                    </RowDefinition>
                    <RowDefinition>
                        <RowDefinition.Height>
                            <MultiBinding Converter="{StaticResource MobileGraphRowHeightConverter}" ConverterParameter="3">
                                <Binding Path="Workspace.ImuGraphState" />
                                <Binding ElementName="PageScrollViewer" Path="Bounds.Height" />
                            </MultiBinding>
                        </RowDefinition.Height>
                    </RowDefinition>
                    <RowDefinition>
                        <RowDefinition.Height>
                            <MultiBinding Converter="{StaticResource MobileGraphRowHeightConverter}" ConverterParameter="3">
                                <Binding Path="Workspace.SpeedGraphState" />
                                <Binding ElementName="PageScrollViewer" Path="Bounds.Height" />
                            </MultiBinding>
                        </RowDefinition.Height>
                    </RowDefinition>
                    <RowDefinition>
                        <RowDefinition.Height>
                            <MultiBinding Converter="{StaticResource MobileGraphRowHeightConverter}" ConverterParameter="3">
                                <Binding Path="Workspace.ElevationGraphState" />
                                <Binding ElementName="PageScrollViewer" Path="Bounds.Height" />
                            </MultiBinding>
                        </RowDefinition.Height>
                    </RowDefinition>
                </Grid.RowDefinitions>

                <controls:PlaceholderOverlayContainer Grid.Row="0" PresentationState="{Binding Workspace.TravelGraphState}">
                    <controls:PlaceholderOverlayContainer.ReadyContent>
                        <plots:LiveTravelPlotDesktopView
                        x:Name="TravelPlot"
                        GraphBatches="{Binding Workspace.GraphBatches}"
                        HideRightAxis="True"
                        MaximumY="{Binding Workspace.PlotRanges.TravelMaximum}"
                        SmoothingLevel="{Binding Workspace.PlotPreferences.TravelSmoothing}"
                        Timeline="{Binding Workspace.Timeline}" />
                    </controls:PlaceholderOverlayContainer.ReadyContent>
                    <controls:PlaceholderOverlayContainer.PlaceholderContent>
                        <controls:SurfacePlaceholderCard Title="Travel" />
                    </controls:PlaceholderOverlayContainer.PlaceholderContent>
                </controls:PlaceholderOverlayContainer>

                <controls:PlaceholderOverlayContainer Grid.Row="1" PresentationState="{Binding Workspace.VelocityGraphState}">
                    <controls:PlaceholderOverlayContainer.ReadyContent>
                        <plots:LiveVelocityPlotDesktopView
                        x:Name="VelocityPlot"
                        Margin="0,4,0,0"
                        GraphBatches="{Binding Workspace.GraphBatches}"
                        HideRightAxis="True"
                        MaximumY="{Binding Workspace.PlotRanges.VelocityMaximum}"
                        MinimumY="{Binding Workspace.PlotRanges.VelocityMinimum}"
                        SmoothingLevel="{Binding Workspace.PlotPreferences.VelocitySmoothing}"
                        Timeline="{Binding Workspace.Timeline}" />
                    </controls:PlaceholderOverlayContainer.ReadyContent>
                    <controls:PlaceholderOverlayContainer.PlaceholderContent>
                        <controls:SurfacePlaceholderCard Title="Velocity" Margin="0,4,0,0" />
                    </controls:PlaceholderOverlayContainer.PlaceholderContent>
                </controls:PlaceholderOverlayContainer>

                <controls:PlaceholderOverlayContainer Grid.Row="2" PresentationState="{Binding Workspace.ImuGraphState}">
                    <controls:PlaceholderOverlayContainer.ReadyContent>
                        <plots:LiveImuPlotDesktopView
                        x:Name="ImuPlot"
                        Margin="0,4,0,0"
                        GraphBatches="{Binding Workspace.GraphBatches}"
                        HideRightAxis="True"
                        MaximumY="{Binding Workspace.PlotRanges.ImuMaximum}"
                        SmoothingLevel="{Binding Workspace.PlotPreferences.ImuSmoothing}"
                        Timeline="{Binding Workspace.Timeline}" />
                    </controls:PlaceholderOverlayContainer.ReadyContent>
                    <controls:PlaceholderOverlayContainer.PlaceholderContent>
                        <controls:SurfacePlaceholderCard Title="IMU" Margin="0,4,0,0" />
                    </controls:PlaceholderOverlayContainer.PlaceholderContent>
                </controls:PlaceholderOverlayContainer>

                <controls:PlaceholderOverlayContainer Grid.Row="3" PresentationState="{Binding Workspace.SpeedGraphState}">
                    <controls:PlaceholderOverlayContainer.ReadyContent>
                        <plots:TrackSignalPlotDesktopView
                        x:Name="SpeedPlot"
                        HideRightAxis="True"
                        Margin="0,4,0,0"
                        SignalKind="{x:Static plotModels:TrackSignalKind.Speed}"
                        SmoothingLevel="{Binding Workspace.PlotPreferences.SpeedSmoothing}"
                        Timeline="{Binding Workspace.Timeline}"
                        TimelineContext="{Binding Workspace.TrackTimelineContext}"
                        TrackPoints="{Binding Workspace.TrackPoints}" />
                    </controls:PlaceholderOverlayContainer.ReadyContent>
                    <controls:PlaceholderOverlayContainer.PlaceholderContent>
                        <controls:SurfacePlaceholderCard Title="Speed" Margin="0,4,0,0" />
                    </controls:PlaceholderOverlayContainer.PlaceholderContent>
                </controls:PlaceholderOverlayContainer>

                <controls:PlaceholderOverlayContainer Grid.Row="4" PresentationState="{Binding Workspace.ElevationGraphState}">
                    <controls:PlaceholderOverlayContainer.ReadyContent>
                        <plots:TrackSignalPlotDesktopView
                        x:Name="ElevationPlot"
                        HideRightAxis="True"
                        Margin="0,4,0,0"
                        SignalKind="{x:Static plotModels:TrackSignalKind.Elevation}"
                        SmoothingLevel="{Binding Workspace.PlotPreferences.ElevationSmoothing}"
                        Timeline="{Binding Workspace.Timeline}"
                        TimelineContext="{Binding Workspace.TrackTimelineContext}"
                        TrackPoints="{Binding Workspace.TrackPoints}" />
                    </controls:PlaceholderOverlayContainer.ReadyContent>
                    <controls:PlaceholderOverlayContainer.PlaceholderContent>
                        <controls:SurfacePlaceholderCard Title="Elevation" Margin="0,4,0,0" />
                    </controls:PlaceholderOverlayContainer.PlaceholderContent>
                </controls:PlaceholderOverlayContainer>
            </Grid>

            <controls:PlaceholderOverlayContainer
            Name="MapHost"
            Height="320"
            IsVisible="{Binding MediaWorkspace.MapState.ReservesLayout}"
            PresentationState="{Binding MediaWorkspace.MapState}">
                <controls:PlaceholderOverlayContainer.ReadyContent>
                    <v:MapView
                    Name="MobileMapView"
                    DataContext="{Binding MediaWorkspace.MapViewModel}"
                    Timeline="{Binding $parent[controls:PlaceholderOverlayContainer].DataContext.MediaWorkspace.Timeline}" />
                </controls:PlaceholderOverlayContainer.ReadyContent>
                <controls:PlaceholderOverlayContainer.PlaceholderContent>
                    <controls:SurfacePlaceholderCard Title="Map" />
                </controls:PlaceholderOverlayContainer.PlaceholderContent>
            </controls:PlaceholderOverlayContainer>
        </StackPanel>
    </ScrollViewer>

</UserControl>
