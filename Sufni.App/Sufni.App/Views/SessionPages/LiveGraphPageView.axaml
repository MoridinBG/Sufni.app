<UserControl
x:Class="Sufni.App.Views.SessionPages.LiveGraphPageView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:models="clr-namespace:Sufni.App.Models"
xmlns:plotModels="clr-namespace:Sufni.App.Plots"
xmlns:plots="clr-namespace:Sufni.App.DesktopViews.Plots"
xmlns:v="clr-namespace:Sufni.App.Views"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.SessionPages"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:LiveGraphPageViewModel"
mc:Ignorable="d">

    <ScrollViewer
    x:Name="PageScrollViewer"
    Width="{Binding $parent[ScrollViewer].Bounds.Width}"
    IsScrollChainingEnabled="False">
        <StackPanel Spacing="10">
            <Grid MinHeight="{Binding #PageScrollViewer.Bounds.Height}">
                <controls:TelemetryPlotsRoot
                x:Name="GraphRoot"
                Margin="-8,0,-8,0"
                GraphPreferences="{Binding Workspace.GraphPreferences, Mode=TwoWay}">
                    <controls:TelemetryPlotsRoot.Rows>
                        <controls:TelemetryPlotRow
                        RowId="{x:Static models:TelemetryGraphRowIds.Travel}"
                        Title="Travel (mm)"
                        PresentationState="{Binding Workspace.TravelGraphState}">
                            <controls:TelemetryPlotRow.PlotContent>
                                <plots:LiveTravelPlotDesktopView
                                x:Name="TravelPlot"
                                GraphBatches="{Binding Workspace.GraphBatches}"
                                HideRightAxis="True"
                                MaximumY="{Binding Workspace.PlotRanges.TravelMaximum}"
                                SmoothingLevel="{Binding Workspace.PlotPreferences.TravelSmoothing}"
                                Timeline="{Binding Workspace.Timeline}" />
                            </controls:TelemetryPlotRow.PlotContent>
                            <controls:TelemetryPlotRow.PlaceholderContent>
                                <controls:SurfacePlaceholderCard Title="Travel" />
                            </controls:TelemetryPlotRow.PlaceholderContent>
                            <controls:TelemetryPlotRow.ChildRows>
                                <controls:TelemetryPlotRow
                                RowId="{x:Static models:TelemetryGraphRowIds.Velocity}"
                                Title="Velocity (m/s)"
                                PresentationState="{Binding Workspace.VelocityGraphState}">
                                    <controls:TelemetryPlotRow.PlotContent>
                                        <plots:LiveVelocityPlotDesktopView
                                        x:Name="VelocityPlot"
                                        GraphBatches="{Binding Workspace.GraphBatches}"
                                        HideRightAxis="True"
                                        MaximumY="{Binding Workspace.PlotRanges.VelocityMaximum}"
                                        MinimumY="{Binding Workspace.PlotRanges.VelocityMinimum}"
                                        SmoothingLevel="{Binding Workspace.PlotPreferences.VelocitySmoothing}"
                                        Timeline="{Binding Workspace.Timeline}" />
                                    </controls:TelemetryPlotRow.PlotContent>
                                    <controls:TelemetryPlotRow.PlaceholderContent>
                                        <controls:SurfacePlaceholderCard Title="Velocity" />
                                    </controls:TelemetryPlotRow.PlaceholderContent>
                                </controls:TelemetryPlotRow>
                            </controls:TelemetryPlotRow.ChildRows>
                        </controls:TelemetryPlotRow>

                        <controls:TelemetryPlotRow
                        RowId="{x:Static models:TelemetryGraphRowIds.Imu}"
                        Title="IMU acceleration (g)"
                        PresentationState="{Binding Workspace.ImuGraphState}">
                            <controls:TelemetryPlotRow.PlotContent>
                                <plots:LiveImuPlotDesktopView
                                x:Name="ImuPlot"
                                GraphBatches="{Binding Workspace.GraphBatches}"
                                HideRightAxis="True"
                                MaximumY="{Binding Workspace.PlotRanges.ImuMaximum}"
                                SmoothingLevel="{Binding Workspace.PlotPreferences.ImuSmoothing}"
                                Timeline="{Binding Workspace.Timeline}" />
                            </controls:TelemetryPlotRow.PlotContent>
                            <controls:TelemetryPlotRow.PlaceholderContent>
                                <controls:SurfacePlaceholderCard Title="IMU" />
                            </controls:TelemetryPlotRow.PlaceholderContent>
                        </controls:TelemetryPlotRow>

                        <controls:TelemetryPlotRow
                        RowId="{x:Static models:TelemetryGraphRowIds.Speed}"
                        Title="GPS speed (km/h)"
                        PresentationState="{Binding Workspace.SpeedGraphState}">
                            <controls:TelemetryPlotRow.PlotContent>
                                <plots:TrackSignalPlotDesktopView
                                x:Name="SpeedPlot"
                                HideRightAxis="True"
                                SignalKind="{x:Static plotModels:TrackSignalKind.Speed}"
                                SmoothingLevel="{Binding Workspace.PlotPreferences.SpeedSmoothing}"
                                Timeline="{Binding Workspace.Timeline}"
                                TimelineContext="{Binding Workspace.TrackTimelineContext}"
                                TrackPoints="{Binding Workspace.TrackPoints}" />
                            </controls:TelemetryPlotRow.PlotContent>
                            <controls:TelemetryPlotRow.PlaceholderContent>
                                <controls:SurfacePlaceholderCard Title="Speed" />
                            </controls:TelemetryPlotRow.PlaceholderContent>
                            <controls:TelemetryPlotRow.ChildRows>
                                <controls:TelemetryPlotRow
                                RowId="{x:Static models:TelemetryGraphRowIds.Elevation}"
                                Title="Elevation (m)"
                                PresentationState="{Binding Workspace.ElevationGraphState}">
                                    <controls:TelemetryPlotRow.PlotContent>
                                        <plots:TrackSignalPlotDesktopView
                                        x:Name="ElevationPlot"
                                        HideRightAxis="True"
                                        SignalKind="{x:Static plotModels:TrackSignalKind.Elevation}"
                                        SmoothingLevel="{Binding Workspace.PlotPreferences.ElevationSmoothing}"
                                        Timeline="{Binding Workspace.Timeline}"
                                        TimelineContext="{Binding Workspace.TrackTimelineContext}"
                                        TrackPoints="{Binding Workspace.TrackPoints}" />
                                    </controls:TelemetryPlotRow.PlotContent>
                                    <controls:TelemetryPlotRow.PlaceholderContent>
                                        <controls:SurfacePlaceholderCard Title="Elevation" />
                                    </controls:TelemetryPlotRow.PlaceholderContent>
                                </controls:TelemetryPlotRow>
                            </controls:TelemetryPlotRow.ChildRows>
                        </controls:TelemetryPlotRow>
                    </controls:TelemetryPlotsRoot.Rows>
                </controls:TelemetryPlotsRoot>
            </Grid>

            <controls:PlaceholderOverlayContainer
            Name="MapHost"
            Height="320"
            IsVisible="{Binding MediaWorkspace.MapState.ReservesLayout}"
            PresentationState="{Binding MediaWorkspace.MapState}">
                <controls:PlaceholderOverlayContainer.ReadyContent>
                    <v:MapView
                    Name="MobileMapView"
                    DataContext="{Binding MediaWorkspace.MapViewModel}"
                    Timeline="{Binding $parent[controls:PlaceholderOverlayContainer].DataContext.MediaWorkspace.Timeline}" />
                </controls:PlaceholderOverlayContainer.ReadyContent>
                <controls:PlaceholderOverlayContainer.PlaceholderContent>
                    <controls:SurfacePlaceholderCard Title="Map" />
                </controls:PlaceholderOverlayContainer.PlaceholderContent>
            </controls:PlaceholderOverlayContainer>
        </StackPanel>
    </ScrollViewer>

</UserControl>
