<UserControl
x:Class="Sufni.App.Views.SessionPages.NotesPageView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.SessionPages"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:NotesPageViewModel"
mc:Ignorable="d">

    <Grid
    Width="{Binding $parent[ScrollViewer].Bounds.Width}"
    Margin="0,10,0,0"
    ColumnDefinitions="15 auto 10 * 6 * 15"
    RowDefinitions="auto auto auto auto auto auto auto auto auto auto">

        <Grid.Styles>
            <Style Selector="NumericUpDown">
                <Setter Property="Minimum" Value="0" />
                <Setter Property="Increment" Value="1" />
                <Setter Property="Margin" Value="2" />
            </Style>
        </Grid.Styles>

        <!--  Notes box  -->
        <Label
        Grid.Row="0"
        Grid.Column="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Content="Notes:" />
        <TextBox
        Name="DescriptionTextBox"
        Grid.Row="0"
        Grid.Column="3"
        Grid.ColumnSpan="3"
        MinHeight="150"
        Margin="2"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        VerticalContentAlignment="Top"
        AcceptsReturn="True"
        Text="{Binding Description}"
        TextWrapping="Wrap" />

        <!--  Temperature averages  -->
        <StackPanel
        Name="TemperatureAveragesPanel"
        Grid.Row="1"
        Grid.Column="1"
        Grid.ColumnSpan="5"
        Margin="0,12,0,8"
        IsVisible="{Binding HasTemperatureAverages}"
        Spacing="4">
            <TextBlock FontWeight="SemiBold" Text="Temperature averages" />
            <ItemsControl
            Name="TemperatureAveragesItemsControl"
            ItemsSource="{Binding TemperatureAverages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TemperatureAverageRowViewModel">
                        <Grid ColumnDefinitions="* auto" Margin="0,1">
                            <TextBlock Grid.Column="0" Text="{Binding SensorName}" />
                            <TextBlock
                            Grid.Column="1"
                            FontWeight="SemiBold"
                            Text="{Binding TemperatureText}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!--  Header row  -->
        <Label
        Grid.Row="2"
        Grid.Column="3"
        HorizontalAlignment="Center"
        Content="Front" />
        <Label
        Grid.Row="2"
        Grid.Column="5"
        HorizontalAlignment="Center"
        Content="Rear" />

        <!--  Spring row  -->
        <Label
        Grid.Row="3"
        Grid.Column="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Content="Spring:" />
        <TextBox
        Name="ForkSpringRateTextBox"
        Grid.Row="3"
        Grid.Column="3"
        Margin="2"
        VerticalContentAlignment="Center"
        Text="{Binding ForkSettings.SpringRate}" />
        <TextBox
        Name="ShockSpringRateTextBox"
        Grid.Row="3"
        Grid.Column="5"
        Margin="2"
        VerticalContentAlignment="Center"
        Text="{Binding ShockSettings.SpringRate}" />

        <!--  HSC row  -->
        <Label
        Grid.Row="4"
        Grid.Column="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Content="HSC:" />
        <NumericUpDown
        Name="ForkHscInput"
        Grid.Row="4"
        Grid.Column="3"
        Value="{Binding ForkSettings.HighSpeedCompression}" />
        <NumericUpDown
        Name="ShockHscInput"
        Grid.Row="4"
        Grid.Column="5"
        Value="{Binding ShockSettings.HighSpeedCompression}" />

        <!--  LSC row  -->
        <Label
        Grid.Row="5"
        Grid.Column="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Content="LSC:" />
        <NumericUpDown
        Grid.Row="5"
        Grid.Column="3"
        Value="{Binding ForkSettings.LowSpeedCompression}" />
        <NumericUpDown
        Grid.Row="5"
        Grid.Column="5"
        Value="{Binding ShockSettings.LowSpeedCompression}" />

        <!--  LSR row  -->
        <Label
        Grid.Row="6"
        Grid.Column="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Content="LSR:" />
        <NumericUpDown
        Grid.Row="6"
        Grid.Column="3"
        Value="{Binding ForkSettings.LowSpeedRebound}" />
        <NumericUpDown
        Grid.Row="6"
        Grid.Column="5"
        Value="{Binding ShockSettings.LowSpeedRebound}" />

        <!--  HSR row  -->
        <Label
        Grid.Row="7"
        Grid.Column="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Content="HSR:" />
        <NumericUpDown
        Name="ForkHsrInput"
        Grid.Row="7"
        Grid.Column="3"
        Value="{Binding ForkSettings.HighSpeedRebound}" />
        <NumericUpDown
        Name="ShockHsrInput"
        Grid.Row="7"
        Grid.Column="5"
        Value="{Binding ShockSettings.HighSpeedRebound}" />
    </Grid>
</UserControl>
