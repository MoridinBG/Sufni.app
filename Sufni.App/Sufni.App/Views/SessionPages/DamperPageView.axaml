<UserControl
x:Class="Sufni.App.Views.SessionPages.DamperPageView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:desktopplots="clr-namespace:Sufni.App.DesktopViews.Plots"
xmlns:plots="clr-namespace:Sufni.App.Views.Plots"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.SessionPages"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:DamperPageViewModel"
mc:Ignorable="d">

    <ScrollViewer Width="{Binding $parent[ScrollViewer].Bounds.Width}" IsScrollChainingEnabled="False">
        <StackPanel Orientation="Vertical" Spacing="8">
            <StackPanel
            Name="MobileVelocityAverageModeRadioButtons"
            Margin="0,8,0,0"
            IsVisible="{Binding HasDynamicStatistics}"
            Spacing="4">
                <RadioButton
                Name="MobileSampleAveragedModeRadioButton"
                Content="Sample-averaged"
                GroupName="MobileVelocityAverageMode"
                IsChecked="{Binding SampleAveragedModeSelected, Mode=TwoWay}"
                ToolTip.Tip="Uses every stroke sample for bars and average labels." />
                <RadioButton
                Name="MobileStrokePeakAveragedModeRadioButton"
                Content="Stroke-peak average"
                GroupName="MobileVelocityAverageMode"
                IsChecked="{Binding StrokePeakAveragedModeSelected, Mode=TwoWay}"
                ToolTip.Tip="Uses one peak-speed event per stroke for bars and average labels." />
            </StackPanel>

            <controls:PlaceholderOverlayContainer PresentationState="{Binding FrontPresentationState}">
                <controls:PlaceholderOverlayContainer.ReadyContent>
                    <Grid Name="FrontHistogramRow" ColumnDefinitions="* auto">
                        <Grid Grid.Column="0">
                            <desktopplots:SessionStatisticsPlotView
                            Name="FrontVelocityHistogramPlot"
                            Height="260"
                            AnalysisRange="{Binding StatisticsWorkspace.AnalysisRange}"
                            IsVisible="{Binding HasDynamicStatistics}"
                            PlotKind="VelocityHistogram"
                            SuspensionType="Front"
                            Telemetry="{Binding StatisticsWorkspace.TelemetryData}"
                            VelocityAverageMode="{Binding StatisticsWorkspace.SelectedVelocityAverageMode}" />

                            <Svg
                            Name="FrontVelocityHistogramSvg"
                            IsVisible="{Binding !HasDynamicStatistics}"
                            Source="{Binding FrontVelocityHistogram}" />
                        </Grid>
                        <plots:VelocityBandView
                        Name="FrontVelocityBands"
                        Grid.Column="1"
                        HscPercentage="{Binding FrontHscPercentage}"
                        HsrPercentage="{Binding FrontHsrPercentage}"
                        LscPercentage="{Binding FrontLscPercentage}"
                        LsrPercentage="{Binding FrontLsrPercentage}" />
                    </Grid>
                </controls:PlaceholderOverlayContainer.ReadyContent>
                <controls:PlaceholderOverlayContainer.PlaceholderContent>
                    <controls:SurfacePlaceholderCard Margin="0,0,0,12" Title="Front damping" MinCardHeight="220" />
                </controls:PlaceholderOverlayContainer.PlaceholderContent>
            </controls:PlaceholderOverlayContainer>

            <controls:PlaceholderOverlayContainer PresentationState="{Binding RearPresentationState}">
                <controls:PlaceholderOverlayContainer.ReadyContent>
                    <Grid Name="RearHistogramRow" ColumnDefinitions="* auto">
                        <Grid Grid.Column="0">
                            <desktopplots:SessionStatisticsPlotView
                            Name="RearVelocityHistogramPlot"
                            Height="260"
                            AnalysisRange="{Binding StatisticsWorkspace.AnalysisRange}"
                            IsVisible="{Binding HasDynamicStatistics}"
                            PlotKind="VelocityHistogram"
                            SuspensionType="Rear"
                            Telemetry="{Binding StatisticsWorkspace.TelemetryData}"
                            VelocityAverageMode="{Binding StatisticsWorkspace.SelectedVelocityAverageMode}" />

                            <Svg
                            Name="RearVelocityHistogramSvg"
                            IsVisible="{Binding !HasDynamicStatistics}"
                            Source="{Binding RearVelocityHistogram}" />
                        </Grid>
                        <plots:VelocityBandView
                        Name="RearVelocityBands"
                        Grid.Column="1"
                        HscPercentage="{Binding RearHscPercentage}"
                        HsrPercentage="{Binding RearHsrPercentage}"
                        LscPercentage="{Binding RearLscPercentage}"
                        LsrPercentage="{Binding RearLsrPercentage}" />
                    </Grid>
                </controls:PlaceholderOverlayContainer.ReadyContent>
                <controls:PlaceholderOverlayContainer.PlaceholderContent>
                    <controls:SurfacePlaceholderCard Title="Rear damping" MinCardHeight="220" />
                </controls:PlaceholderOverlayContainer.PlaceholderContent>
            </controls:PlaceholderOverlayContainer>

        </StackPanel>
    </ScrollViewer>
</UserControl>
