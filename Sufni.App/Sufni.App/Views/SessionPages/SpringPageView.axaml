<UserControl
x:Class="Sufni.App.Views.SessionPages.SpringPageView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:plots="clr-namespace:Sufni.App.DesktopViews.Plots"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.SessionPages"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:SpringPageViewModel"
mc:Ignorable="d">

    <ScrollViewer Width="{Binding $parent[ScrollViewer].Bounds.Width}" IsScrollChainingEnabled="False">
        <StackPanel Orientation="Vertical" Spacing="8">
            <StackPanel
            Name="MobileTravelHistogramModeRadioButtons"
            Margin="0,8,0,0"
            IsVisible="{Binding HasDynamicStatistics}"
            Spacing="4">
                <RadioButton
                Name="MobileActiveSuspensionModeRadioButton"
                Content="Active suspension"
                GroupName="MobileTravelHistogramMode"
                IsChecked="{Binding ActiveSuspensionModeSelected, Mode=TwoWay}"
                ToolTip.Tip="Uses compression and rebound stroke samples only." />
                <RadioButton
                Name="MobileDynamicSagModeRadioButton"
                Content="Dynamic sag"
                GroupName="MobileTravelHistogramMode"
                IsChecked="{Binding DynamicSagModeSelected, Mode=TwoWay}"
                ToolTip.Tip="Uses all selected travel samples." />
            </StackPanel>

            <controls:PlaceholderOverlayContainer PresentationState="{Binding FrontPresentationState}">
                <controls:PlaceholderOverlayContainer.ReadyContent>
                    <Grid>
                        <plots:SessionStatisticsPlotView
                        Name="FrontTravelHistogramPlot"
                        Height="260"
                        AnalysisRange="{Binding StatisticsWorkspace.AnalysisRange}"
                        IsVisible="{Binding HasDynamicStatistics}"
                        PlotKind="TravelHistogram"
                        SuspensionType="Front"
                        Telemetry="{Binding StatisticsWorkspace.TelemetryData}"
                        TravelHistogramMode="{Binding StatisticsWorkspace.SelectedTravelHistogramMode}" />

                        <Svg
                        Name="FrontHistogramSvg"
                        IsVisible="{Binding !HasDynamicStatistics}"
                        Source="{Binding FrontTravelHistogram}" />
                    </Grid>
                </controls:PlaceholderOverlayContainer.ReadyContent>
                <controls:PlaceholderOverlayContainer.PlaceholderContent>
                    <controls:SurfacePlaceholderCard Margin="0,0,0,12" Title="Front travel" MinCardHeight="220" />
                </controls:PlaceholderOverlayContainer.PlaceholderContent>
            </controls:PlaceholderOverlayContainer>

            <controls:PlaceholderOverlayContainer PresentationState="{Binding RearPresentationState}">
                <controls:PlaceholderOverlayContainer.ReadyContent>
                    <Grid>
                        <plots:SessionStatisticsPlotView
                        Name="RearTravelHistogramPlot"
                        Height="260"
                        AnalysisRange="{Binding StatisticsWorkspace.AnalysisRange}"
                        IsVisible="{Binding HasDynamicStatistics}"
                        PlotKind="TravelHistogram"
                        SuspensionType="Rear"
                        Telemetry="{Binding StatisticsWorkspace.TelemetryData}"
                        TravelHistogramMode="{Binding StatisticsWorkspace.SelectedTravelHistogramMode}" />

                        <Svg
                        Name="RearHistogramSvg"
                        IsVisible="{Binding !HasDynamicStatistics}"
                        Source="{Binding RearTravelHistogram}" />
                    </Grid>
                </controls:PlaceholderOverlayContainer.ReadyContent>
                <controls:PlaceholderOverlayContainer.PlaceholderContent>
                    <controls:SurfacePlaceholderCard Title="Rear travel" MinCardHeight="220" />
                </controls:PlaceholderOverlayContainer.PlaceholderContent>
            </controls:PlaceholderOverlayContainer>
        </StackPanel>
    </ScrollViewer>

</UserControl>
