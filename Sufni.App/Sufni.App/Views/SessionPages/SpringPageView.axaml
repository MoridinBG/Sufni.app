<UserControl
x:Class="Sufni.App.Views.SessionPages.SpringPageView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.SessionPages"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:SpringPageViewModel"
mc:Ignorable="d">

    <ScrollViewer Width="{Binding $parent[ScrollViewer].Bounds.Width}" IsScrollChainingEnabled="False">
        <StackPanel Orientation="Vertical" Spacing="8">
            <StackPanel
            Name="MobileTravelHistogramModeRadioButtons"
            Margin="0,8,0,0"
            IsVisible="{Binding HasDynamicStatistics}"
            Spacing="4">
                <RadioButton
                Name="MobileActiveSuspensionModeRadioButton"
                Content="Active suspension"
                GroupName="MobileTravelHistogramMode"
                IsChecked="{Binding ActiveSuspensionModeSelected, Mode=TwoWay}"
                ToolTip.Tip="Uses only compression and rebound stroke samples. Best for travel use while the suspension is actively moving." />
                <RadioButton
                Name="MobileDynamicSagModeRadioButton"
                Content="Dynamic sag"
                GroupName="MobileTravelHistogramMode"
                IsChecked="{Binding DynamicSagModeSelected, Mode=TwoWay}"
                ToolTip.Tip="Uses every selected travel sample. Best for ride height over the segment, including quiet or steady sections." />
            </StackPanel>

            <controls:TravelStatisticsHost
            AnalysisRange="{Binding StatisticsWorkspace.AnalysisRange}"
            HasDynamicStatistics="{Binding HasDynamicStatistics}"
            MinCardHeight="220"
            PlaceholderMargin="0,0,0,12"
            PlotHeight="260"
            PresentationState="{Binding FrontPresentationState}"
            StaticSource="{Binding FrontTravelHistogram}"
            SuspensionType="Front"
            Telemetry="{Binding StatisticsWorkspace.TelemetryData}"
            Title="Front travel"
            TravelHistogramMode="{Binding StatisticsWorkspace.SelectedTravelHistogramMode}" />

            <controls:TravelStatisticsHost
            AnalysisRange="{Binding StatisticsWorkspace.AnalysisRange}"
            HasDynamicStatistics="{Binding HasDynamicStatistics}"
            MinCardHeight="220"
            PlotHeight="260"
            PresentationState="{Binding RearPresentationState}"
            StaticSource="{Binding RearTravelHistogram}"
            SuspensionType="Rear"
            Telemetry="{Binding StatisticsWorkspace.TelemetryData}"
            Title="Rear travel"
            TravelHistogramMode="{Binding StatisticsWorkspace.SelectedTravelHistogramMode}" />
        </StackPanel>
    </ScrollViewer>

</UserControl>
