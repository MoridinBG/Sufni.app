<UserControl
x:Class="Sufni.App.Views.SessionPages.RecordedGraphPageView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:sessionGraphs="clr-namespace:Sufni.App.SessionGraphs"
xmlns:v="clr-namespace:Sufni.App.Views"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.SessionPages"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:RecordedGraphPageViewModel"
mc:Ignorable="d">

    <ScrollViewer
    x:Name="PageScrollViewer"
    Width="{Binding $parent[ScrollViewer].Bounds.Width}"
    IsScrollChainingEnabled="False">
        <StackPanel Spacing="10">
            <Grid MinHeight="{Binding #PageScrollViewer.Bounds.Height}">
                <controls:RecordedSessionGraphRowsView
                Margin="-8,0,-8,0"
                DataContext="{Binding Workspace}"
                HideRightAxis="True"
                MaximumDisplayHz="{x:Static sessionGraphs:SessionGraphSettings.RecordedMobileMaximumDisplayHz}" />

                <controls:SurfacePlaceholderCard
                Name="NoGraphDataPlaceholder"
                MinCardHeight="280"
                Title="No graph data for this session.">
                    <controls:SurfacePlaceholderCard.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!Workspace.TravelGraphState.ReservesLayout" />
                            <Binding Path="!Workspace.VelocityGraphState.ReservesLayout" />
                            <Binding Path="!Workspace.ImuGraphState.ReservesLayout" />
                            <Binding Path="!Workspace.PitchRollGraphState.ReservesLayout" />
                            <Binding Path="!Workspace.SpeedGraphState.ReservesLayout" />
                            <Binding Path="!Workspace.ElevationGraphState.ReservesLayout" />
                        </MultiBinding>
                    </controls:SurfacePlaceholderCard.IsVisible>
                </controls:SurfacePlaceholderCard>
            </Grid>

            <controls:PlaceholderOverlayContainer
            Name="MapHost"
            Height="320"
            IsVisible="{Binding MediaWorkspace.MapState.ReservesLayout}"
            PresentationState="{Binding MediaWorkspace.MapState}">
                <controls:PlaceholderOverlayContainer.ReadyContent>
                    <v:MapView
                    Name="MobileMapView"
                    DataContext="{Binding MediaWorkspace.MapViewModel}"
                    Timeline="{Binding $parent[controls:PlaceholderOverlayContainer].DataContext.MediaWorkspace.Timeline}" />
                </controls:PlaceholderOverlayContainer.ReadyContent>
                <controls:PlaceholderOverlayContainer.PlaceholderContent>
                    <controls:SurfacePlaceholderCard Title="Map" />
                </controls:PlaceholderOverlayContainer.PlaceholderContent>
            </controls:PlaceholderOverlayContainer>
        </StackPanel>
    </ScrollViewer>

</UserControl>
