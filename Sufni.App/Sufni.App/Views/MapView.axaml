<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Sufni.App.Views"
    xmlns:models="using:Sufni.App.Models"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia">
    <Design.PreviewWith>
        <controls:MapView />
    </Design.PreviewWith>

    <Style Selector="controls|MapView">
        <!--  Set Defaults  -->
        <Setter Property="Template">
            <ControlTemplate>
                <Grid>
                    <mapsui:MapControl Name="MapControl" />

                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="10" Padding="5"
                            Background="{StaticResource SufniBackground}"
                            CornerRadius="5" Opacity="0.9">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <ComboBox Name="TileProviderComboBox"
                                      MinWidth="120"
                                      PlaceholderText="Select Map...">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:TileLayerConfig">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Name="AddCustomTileButton" Content="+" Padding="10,0" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
