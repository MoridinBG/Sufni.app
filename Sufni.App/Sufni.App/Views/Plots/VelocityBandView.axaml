<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Sufni.App.Views.Plots">
    <Design.PreviewWith>
        <controls:VelocityBandView />
    </Design.PreviewWith>

    <Style Selector="controls|VelocityBandView">
        <!--  Set Defaults  -->
        <Setter Property="MinWidth" Value="68" />
        <Setter Property="MaxWidth" Value="84" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="Auto" RowDefinitions="39 * 39">

                    <!--  Title  -->
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,3,0,5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        FontWeight="Bold"
                        Foreground="{DynamicResource SufniTextPrimaryBrush}"
                        Text="Zone %" />

                    <!--  Bands  -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{Binding Path=HighSpeedZoneLength, RelativeSource={RelativeSource TemplatedParent}}" />
                            <RowDefinition Height="{Binding Path=LowSpeedZoneLength, RelativeSource={RelativeSource TemplatedParent}}" />
                            <RowDefinition Height="{Binding Path=LowSpeedZoneLength, RelativeSource={RelativeSource TemplatedParent}}" />
                            <RowDefinition Height="{Binding Path=HighSpeedZoneLength, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Grid.RowDefinitions>

                        <Grid.Styles>
                            <Styles>
                                <Style Selector="Border">
                                    <Setter Property="BorderThickness" Value="1,0,1,1" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource SufniLineDefaultBrush}" />
                                    <Setter Property="Padding" Value="6,2" />
                                </Style>
                                <Style Selector="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="10" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Foreground" Value="{DynamicResource SufniTextPrimaryBrush}" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    <Setter Property="TextWrapping" Value="NoWrap" />
                                </Style>
                            </Styles>
                        </Grid.Styles>

                        <Border
                            Grid.Row="0"
                            Background="{DynamicResource SufniSurfaceItemHoverBrush}"
                            BorderThickness="1,1,1,1">
                            <TextBlock
                            Text="{Binding Path=HsrPercentage, RelativeSource={RelativeSource TemplatedParent}, StringFormat='HSR {0:0.00}'}"
                            TextAlignment="Center" />
                        </Border>
                        <Border Grid.Row="1" Background="{DynamicResource SufniSurfaceInputBrush}">
                            <TextBlock
                            Text="{Binding Path=LsrPercentage, RelativeSource={RelativeSource TemplatedParent}, StringFormat='LSR {0:0.00}'}"
                            TextAlignment="Center" />
                        </Border>
                        <Border Grid.Row="2" Background="{DynamicResource SufniSurfaceInputBrush}">
                            <TextBlock
                            Text="{Binding Path=LscPercentage, RelativeSource={RelativeSource TemplatedParent}, StringFormat='LSC {0:0.00}'}"
                            TextAlignment="Center" />
                        </Border>
                        <Border Grid.Row="3" Background="{DynamicResource SufniSurfaceItemHoverBrush}">
                            <TextBlock
                            Text="{Binding Path=HscPercentage, RelativeSource={RelativeSource TemplatedParent}, StringFormat='HSC {0:0.00}'}"
                            TextAlignment="Center" />
                        </Border>
                    </Grid>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
