<UserControl
x:Class="Sufni.App.Views.Editors.SessionDetailView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:progRing="clr-namespace:AvaloniaProgressRing;assembly=AvaloniaProgressRing"
xmlns:v="clr-namespace:Sufni.App.Views.Controls"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.Editors"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:SessionDetailViewModel"
Background="{StaticResource SufniRegion}"
Focusable="True"
mc:Ignorable="d">

    <Design.DataContext>
        <vm:SessionDetailViewModel />
    </Design.DataContext>

    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Unloaded">
            <InvokeCommandAction Command="{Binding UnloadedCommand}" />
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <Grid>
        <Grid Margin="20,10,20,10" RowDefinitions="auto auto * auto auto" IsVisible="{Binding ScreenState.IsReady}">

            <!--  Name  -->
            <v:EditableTitle
            Grid.Row="0"
            Margin="0,0,0,10"
            HorizontalAlignment="Stretch" />

            <!--  Tab headers  -->
            <ItemsControl
            Name="TabHeaders"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding Pages}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button
                        Name="{Binding DisplayName}"
                        HorizontalAlignment="Center"
                        Classes="tabheader"
                        Click="OnTabHeaderClicked"
                        Content="{Binding DisplayName}"
                        IsEnabled="{Binding !Selected, Mode=TwoWay}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

                <ItemsControl.Styles>
                    <Style Selector="Button.tabheader">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="CornerRadius" Value="0" />
                        <Setter Property="Padding" Value="0,0,0,10" />
                    </Style>
                    <Style Selector="Button.tabheader:pressed /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Foreground" Value="{StaticResource SufniForeground}" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="Button.tabheader:pressed /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="Button.tabheader:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="Button.tabheader:disabled /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Foreground" Value="{StaticResource SufniForeground}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="{StaticResource SufniAccentColor}" />
                        <Setter Property="Padding" Value="0,0,0,8" />
                        <Setter Property="BorderThickness" Value="0,0,0,2" />
                    </Style>
                </ItemsControl.Styles>

            </ItemsControl>

            <ScrollViewer
            Name="TabScrollViewer"
            Grid.Row="2"
            HorizontalScrollBarVisibility="Hidden"
            HorizontalSnapPointsAlignment="Far"
            HorizontalSnapPointsType="MandatorySingle"
            IsScrollChainingEnabled="False"
            IsScrollInertiaEnabled="False"
            PropertyChanged="TabScrollViewer_OnPropertyChanged"
            SizeChanged="TabScrollViewer_OnSizeChanged"
            VerticalScrollBarVisibility="Disabled">
                <ItemsControl Name="TabContainer" ItemsSource="{Binding Pages}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!--  Ensure that the SufniTelemetryPlotViews' Telemetry property is set  -->
                    <Interaction.Behaviors>
                        <EventTriggerBehavior EventName="Loaded">
                            <InvokeCommandAction Command="{Binding LoadedCommand}" CommandParameter="{Binding ElementName=TabScrollViewer, Path=Bounds}" />
                        </EventTriggerBehavior>
                    </Interaction.Behaviors>

                </ItemsControl>
            </ScrollViewer>

            <!--  Error messages for Session instance  -->
            <v:ErrorMessagesBar Grid.Row="3" Margin="10,5,10,0" />

            <!--  Back, Save, Reset and Delete buttons  -->
            <v:CommonButtonLine Grid.Row="4" Margin="10,0,10,0" />
        </Grid>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" IsVisible="{Binding ScreenState.IsLoading}">
            <progRing:ProgressRing Width="40" Height="40" Foreground="{StaticResource SufniAccentColor}" IsActive="True" />
            <TextBlock HorizontalAlignment="Center" Text="{Binding ScreenState.Message, TargetNullValue=Loading session data...}" />
        </StackPanel>

        <Border HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420" Padding="24" Background="{StaticResource SufniBackground}" BorderBrush="{StaticResource SufniBorderBrush}" BorderThickness="1" CornerRadius="6" IsVisible="{Binding ScreenState.IsError}">
            <StackPanel Spacing="12">
                <TextBlock HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold" Text="Could not load session" />
                <TextBlock HorizontalAlignment="Center" Text="{Binding ScreenState.Message}" TextAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
