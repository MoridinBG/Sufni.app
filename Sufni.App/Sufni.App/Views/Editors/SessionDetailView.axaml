<UserControl
    x:Class="Sufni.App.Views.Editors.SessionDetailView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:v="clr-namespace:Sufni.App.Views.Editors"
    xmlns:vm="clr-namespace:Sufni.App.ViewModels.Editors"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vm:SessionDetailViewModel"
    Background="{StaticResource SufniRegion}"
    Focusable="True"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:SessionDetailViewModel />
    </Design.DataContext>

    <v:SessionShellMobileView
        LoadedCommand="{Binding LoadedCommand}"
        UnloadedCommand="{Binding UnloadedCommand}" />
</UserControl>
