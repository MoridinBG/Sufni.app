<UserControl
x:Class="Sufni.App.Views.ImportSessionsView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:views="clr-namespace:Sufni.App.Views"
xmlns:vm="clr-namespace:Sufni.App.ViewModels"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:ImportSessionsViewModel"
Background="{DynamicResource SufniRegion}"
mc:Ignorable="d">

    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="AttachedToVisualTree">
            <InvokeCommandAction Command="{Binding LoadedCommand}" />
        </EventTriggerBehavior>
        <EventTriggerBehavior EventName="DetachedFromVisualTree">
            <InvokeCommandAction Command="{Binding UnloadedCommand}" />
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <views:ImportSessionsContentView EnableMalformedMessageTap="True">
        <views:ImportSessionsContentView.BottomContent>
            <Grid ColumnDefinitions="auto *">

                <!--  Back button  -->
                <Button
                Grid.Column="0"
                Width="39"
                Height="39"
                Margin="0,0,10,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding OpenPreviousPageCommand}">
                    <Image
                    Width="16"
                    Height="16"
                    Source="{SvgImage /Assets/fa-arrow-left.svg}" />
                </Button>

                <!--  Import button  -->
                <Button
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding ImportSessionsCommand}"
                Content="process selected" />

                <!--  Create Session button  -->
                <Button
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding AddSetupCommand}"
                Content="create setup for this DAQ">
                    <Button.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="SelectedDataStore" />
                            <Binding Converter="{x:Static ObjectConverters.IsNull}" Path="SelectedSetup" />
                        </MultiBinding>
                    </Button.IsVisible>
                </Button>

            </Grid>
        </views:ImportSessionsContentView.BottomContent>
    </views:ImportSessionsContentView>
</UserControl>
