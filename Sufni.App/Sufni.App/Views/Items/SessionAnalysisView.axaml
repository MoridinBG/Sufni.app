<UserControl
x:Class="Sufni.App.Views.Items.SessionAnalysisView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:models="clr-namespace:Sufni.App.Models"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.Editors"
d:DesignHeight="450"
d:DesignWidth="800"
x:DataType="vm:ISessionStatisticsWorkspace"
mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <StackPanel Grid.Column="0">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Analysis" />
                <TextBlock FontSize="12" Opacity="0.75" Text="{Binding SessionAnalysisRangeText}" />
                <TextBlock FontSize="12" Opacity="0.75" Text="{Binding SessionAnalysisModesText}" />
            </StackPanel>

            <ComboBox
            Name="SessionAnalysisTargetProfileComboBox"
            Grid.Column="1"
            Width="150"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            ItemsSource="{Binding SessionAnalysisTargetProfileOptions}"
            SelectedValue="{Binding SelectedSessionAnalysisTargetProfile, Mode=TwoWay}"
            SelectedValueBinding="{Binding Value, DataType=models:SessionAnalysisTargetProfileOption}"
            ToolTip.Tip="Speed references are interpreted through the selected riding context.">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:SessionAnalysisTargetProfileOption">
                        <TextBlock Text="{Binding DisplayName}" ToolTip.Tip="{Binding Description}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <controls:PlaceholderOverlayContainer Grid.Row="1" PresentationState="{Binding SessionAnalysis.State}">
            <controls:PlaceholderOverlayContainer.ReadyContent>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl
                    Name="SessionAnalysisFindingsItemsControl"
                    ItemsSource="{Binding SessionAnalysis.Findings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:SessionAnalysisFinding">
                                <Border
                                Margin="0,0,0,8"
                                Padding="10"
                                BorderBrush="#55606C"
                                BorderThickness="1"
                                CornerRadius="6">
                                    <StackPanel>
                                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,6">
                                            <TextBlock
                                            Grid.Column="0"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Text="{Binding Title}"
                                            TextWrapping="Wrap" />
                                            <TextBlock
                                            Grid.Column="1"
                                            Margin="12,0,0,0"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="{Binding Severity}" />
                                            <TextBlock
                                            Grid.Column="2"
                                            Margin="12,0,0,0"
                                            FontSize="12"
                                            Opacity="0.7"
                                            Text="{Binding Confidence}" />
                                        </Grid>

                                        <TextBlock FontSize="12" Opacity="0.75" Text="{Binding Category}" />
                                        <TextBlock Margin="0,8,0,0" Text="{Binding Observation}" TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding Recommendation}" TextWrapping="Wrap" />

                                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Evidence}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:SessionAnalysisEvidence">
                                                    <Border
                                                    Margin="0,0,6,6"
                                                    Padding="6,4"
                                                    BorderBrush="#46515D"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                        <StackPanel>
                                                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding Label}" />
                                                            <TextBlock FontSize="12" Text="{Binding DisplayValue}" />
                                                            <TextBlock FontSize="10" Opacity="0.7" Text="{Binding Side}" />
                                                            <TextBlock FontSize="10" Opacity="0.7" Text="{Binding SourceMode}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </controls:PlaceholderOverlayContainer.ReadyContent>
            <controls:PlaceholderOverlayContainer.PlaceholderContent>
                <controls:SurfacePlaceholderCard Title="Analysis" />
            </controls:PlaceholderOverlayContainer.PlaceholderContent>
        </controls:PlaceholderOverlayContainer>
    </Grid>
</UserControl>
