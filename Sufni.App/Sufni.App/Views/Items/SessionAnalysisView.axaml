<UserControl
x:Class="Sufni.App.Views.Items.SessionAnalysisView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:models="clr-namespace:Sufni.App.Models"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.Editors"
d:DesignHeight="450"
d:DesignWidth="800"
x:DataType="vm:ISessionStatisticsWorkspace"
mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <StackPanel Grid.Column="0">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Analysis" />
                <TextBlock FontSize="12" Opacity="0.75" Text="{Binding SessionAnalysisRangeText}" />
                <TextBlock FontSize="12" Opacity="0.75" Text="{Binding SessionAnalysisModesText}" />
            </StackPanel>

            <ComboBox
            Name="SessionAnalysisTargetProfileComboBox"
            Grid.Column="1"
            Width="150"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            ItemsSource="{Binding SessionAnalysisTargetProfileOptions}"
            SelectedValue="{Binding SelectedSessionAnalysisTargetProfile, Mode=TwoWay}"
            SelectedValueBinding="{Binding Value, DataType=models:SessionAnalysisTargetProfileOption}"
            ToolTip.Tip="Speed references are interpreted through the selected riding context.">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:SessionAnalysisTargetProfileOption">
                        <TextBlock Text="{Binding DisplayName}" ToolTip.Tip="{Binding Description}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <controls:PlaceholderOverlayContainer Grid.Row="1" PresentationState="{Binding SessionAnalysis.State}">
            <controls:PlaceholderOverlayContainer.ReadyContent>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl
                        Name="SessionAnalysisDataQualityItemsControl"
                        IsVisible="{Binding SessionAnalysis.HasDataQualityFindings}"
                        ItemsSource="{Binding SessionAnalysis.DataQualityFindings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SessionAnalysisFinding">
                                    <Border
                                    Margin="0,0,0,8"
                                    Padding="10"
                                    BorderBrush="#55606C"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,6">
                                                <TextBlock
                                                Grid.Column="0"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Text="{Binding Title}"
                                                TextWrapping="Wrap" />
                                                <TextBlock
                                                Grid.Column="1"
                                                Margin="12,0,0,0"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Text="{Binding Severity}" />
                                                <TextBlock
                                                Grid.Column="2"
                                                Margin="12,0,0,0"
                                                FontSize="12"
                                                Opacity="0.7"
                                                Text="{Binding Confidence}" />
                                            </Grid>

                                            <TextBlock FontSize="12" Opacity="0.75" Text="{Binding Category}" />
                                            <TextBlock Margin="0,8,0,0" Text="{Binding Observation}" TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0" Text="{Binding Recommendation}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl
                        Name="SessionAnalysisStepsItemsControl"
                        ItemsSource="{Binding SessionAnalysis.Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SessionAnalysisStep">
                                    <controls:SessionAnalysisStepView />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ContentControl
                        Name="SessionAnalysisVibrationPanel"
                        Content="{Binding SessionAnalysis.Vibration}"
                        IsVisible="{Binding SessionAnalysis.HasVibration}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate x:DataType="models:SessionAnalysisVibrationPanel">
                                    <controls:SessionAnalysisVibrationPanel />
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </StackPanel>
                </ScrollViewer>
            </controls:PlaceholderOverlayContainer.ReadyContent>
            <controls:PlaceholderOverlayContainer.PlaceholderContent>
                <controls:SurfacePlaceholderCard Title="Analysis" />
            </controls:PlaceholderOverlayContainer.PlaceholderContent>
        </controls:PlaceholderOverlayContainer>
    </Grid>
</UserControl>
