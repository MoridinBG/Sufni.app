<UserControl
    Background="{StaticResource SufniRegion}"
    Focusable="True"
    d:DesignHeight="600"
    d:DesignWidth="500"
    mc:Ignorable="d"
    x:Class="Sufni.App.Views.Items.SetupView"
    x:DataType="vm:SetupViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:v="clr-namespace:Sufni.App.Views.Controls"
    xmlns:vm="clr-namespace:Sufni.App.ViewModels.Items"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:SetupViewModel />
    </Design.DataContext>

    <Grid
        ColumnDefinitions="auto *"
        HorizontalAlignment="Stretch"
        Margin="20,0,20,10"
        MinWidth="300"
        RowDefinitions="auto auto auto auto auto auto auto * auto auto">

        <!--  Name  -->
        <Label
            Content="Name: "
            Grid.Column="0"
            Grid.Row="0"
            VerticalAlignment="Center" />
        <TextBox
            Grid.Column="1"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            Margin="2"
            Text="{Binding Name}" />

        <!--  Board ID  -->
        <Label
            Content="Board ID: "
            Grid.Column="0"
            Grid.Row="1"
            VerticalAlignment="Center" />
        <TextBox
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            Margin="2"
            Text="{Binding BoardId}" />

        <!--  Bike  -->
        <Label
            Content="Bike: "
            Grid.Column="0"
            Grid.Row="2"
            VerticalAlignment="Center" />
        <ComboBox
            Grid.Column="1"
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding Bikes}"
            Margin="2"
            SelectedItem="{Binding SelectedBike}">

            <ComboBox.DataTemplates>
                <DataTemplate DataType="vm:BikeViewModel">
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ComboBox.DataTemplates>
        </ComboBox>

        <!--  Fork sensor type  -->
        <Label
            Content="Fork sensor type: "
            Grid.Column="0"
            Grid.Row="3"
            VerticalAlignment="Center" />
        <ComboBox
            Grid.Column="1"
            Grid.Row="3"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding ForkSensorTypes}"
            Margin="2"
            PlaceholderText=" -- not in use --"
            SelectedItem="{Binding ForkSensorType}" />

        <!--  Fork sensor configuration  -->
        <ContentControl
            Content="{Binding ForkSensorConfiguration}"
            Grid.Column="1"
            Grid.Row="4" />

        <!--  Shock sensor type  -->
        <Label
            Content="Shock sensor type: "
            Grid.Column="0"
            Grid.Row="5"
            VerticalAlignment="Center" />
        <ComboBox
            Grid.Column="1"
            Grid.Row="5"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding ShockSensorTypes}"
            Margin="2"
            PlaceholderText=" -- not in use --"
            SelectedItem="{Binding ShockSensorType}" />

        <!--  Shock sensor configuration  -->
        <ContentControl
            Content="{Binding ShockSensorConfiguration}"
            Grid.Column="1"
            Grid.Row="6" />

        <!--  Error messages for Setup instance  -->
        <v:ErrorMessagesBar
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="8"
            Margin="0,5,0,0" />

        <!--  Back, Save, Reset and Delete buttons  -->
        <v:CommonButtonLine
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="9" />
    </Grid>
</UserControl>