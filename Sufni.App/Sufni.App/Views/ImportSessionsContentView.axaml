<UserControl
x:Class="Sufni.App.Views.ImportSessionsContentView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:v="clr-namespace:Sufni.App.Views.Controls"
xmlns:views="clr-namespace:Sufni.App.Views"
xmlns:vm="clr-namespace:Sufni.App.ViewModels"
d:DesignHeight="600"
d:DesignWidth="500"
x:DataType="vm:ImportSessionsViewModel"
mc:Ignorable="d">

    <UserControl.Resources>
        <v:ImportActionConverter x:Key="ImportActionConverter" />
        <v:ImportActionMatchConverter x:Key="ImportActionMatchConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="ComboBox.importchoice">
            <Setter Property="Width" Value="100" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ComboBox.importchoice.import">
            <Setter Property="Background" Value="{DynamicResource SufniAccentColor}" />
        </Style>
        <Style Selector="ComboBox.importchoice.import:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource SufniAccentColor}" />
        </Style>
        <Style Selector="ComboBox.importchoice.import:pressed /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource SufniAccentColor}" />
        </Style>
        <Style Selector="ComboBox.importchoice.trash">
            <Setter Property="Background" Value="{DynamicResource SufniDangerColor}" />
        </Style>
        <Style Selector="ComboBox.importchoice.trash:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource SufniDangerColor}" />
        </Style>
        <Style Selector="ComboBox.importchoice.trash:pressed /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource SufniDangerColor}" />
        </Style>
    </UserControl.Styles>

    <Grid
    Margin="20,20,20,10"
    ColumnDefinitions="auto * auto"
    RowDefinitions="44 * auto auto 39">

        <!--  Datastore selector  -->
        <ComboBox
        Grid.Row="0"
        Grid.Column="0"
        Grid.ColumnSpan="2"
        Margin="0,0,2,0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        ItemsSource="{Binding TelemetryDataStores}"
        SelectedItem="{Binding SelectedDataStore}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>

            <!--  Attach command to Expanded event  -->
            <Interaction.Behaviors>
                <EventTriggerBehavior EventName="GotFocus">
                    <InvokeCommandAction Command="{Binding ClearNewDataStoresAvailableCommand}" />
                </EventTriggerBehavior>
            </Interaction.Behaviors>
        </ComboBox>

        <Button
        Grid.Row="0"
        Grid.Column="2"
        Width="39"
        Height="39"
        HorizontalContentAlignment="Center"
        BorderBrush="{DynamicResource SufniBorderBrush}"
        Command="{Binding OpenDataStoreCommand}"
        Content="..." />

        <Image
        Grid.Row="0"
        Grid.Column="1"
        Height="20"
        Margin="0,2,40,0"
        HorizontalAlignment="Right"
        IsVisible="{Binding NewDataStoresAvailable}"
        Source="{SvgImage /Assets/fa-circle-exclamation.svg}" />

        <!--  List of SST files in selected datastore  -->
        <ScrollViewer
        Grid.Row="1"
        Grid.Column="0"
        Grid.ColumnSpan="3"
        Margin="0,5,0,5">
            <ItemsRepeater ItemsSource="{Binding TelemetryFiles}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Expander
                        Margin="0,2,0,1"
                        HorizontalAlignment="Stretch"
                        Background="{DynamicResource SufniRegion}"
                        IsExpanded="False">
                            <Expander.Header>
                                <Grid
                                HorizontalAlignment="Stretch"
                                ColumnDefinitions="auto * auto"
                                RowDefinitions="* *">

                                    <!--  Import/Trash/Ignore selector  -->
                                    <ComboBox
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    Classes="importchoice"
                                    Classes.import="{Binding $self.SelectedIndex, Converter={StaticResource ImportActionMatchConverter}, ConverterParameter=Import}"
                                    Classes.trash="{Binding $self.SelectedIndex, Converter={StaticResource ImportActionMatchConverter}, ConverterParameter=Trash}"
                                    SelectedIndex="{Binding ShouldBeImported, Converter={StaticResource ImportActionConverter}, Mode=TwoWay}">
                                        <ComboBox.IsEnabled>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="CanImport" />
                                                <Binding Path="!$parent[views:ImportSessionsContentView].((vm:ImportSessionsViewModel)DataContext).ImportSessionsCommand.IsRunning" />
                                            </MultiBinding>
                                        </ComboBox.IsEnabled>
                                        <ComboBoxItem Content="Ignore" />
                                        <ComboBoxItem Content="Import" />
                                        <ComboBoxItem Content="Trash" />
                                    </ComboBox>

                                    <!--  Name  -->
                                    <StackPanel
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                        <TextBlock
                                        Margin="2"
                                        FontWeight="Black"
                                        Text="{Binding FileName}" />
                                        <TextBlock
                                        Margin="4,2,2,2"
                                        FontWeight="Black"
                                        Foreground="Orange"
                                        Text="(Malformed)"
                                        ToolTip.Tip="{Binding MalformedMessage}">
                                            <TextBlock.IsVisible>
                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                    <Binding
                                                    Converter="{x:Static ObjectConverters.IsNotNull}"
                                                    Path="MalformedMessage" />
                                                    <Binding Path="$parent[views:ImportSessionsContentView].EnableMalformedMessageTap" />
                                                </MultiBinding>
                                            </TextBlock.IsVisible>
                                            <Interaction.Behaviors>
                                                <EventTriggerBehavior EventName="Tapped">
                                                    <InvokeCommandAction
                                                    Command="{Binding $parent[views:ImportSessionsContentView].((vm:ImportSessionsViewModel)DataContext).ShowMalformedMessageCommand}"
                                                    CommandParameter="{Binding}" />
                                                </EventTriggerBehavior>
                                            </Interaction.Behaviors>
                                        </TextBlock>
                                        <TextBlock
                                        Margin="4,2,2,2"
                                        FontWeight="Black"
                                        Foreground="Orange"
                                        Text="(Malformed)"
                                        ToolTip.Tip="{Binding MalformedMessage}">
                                            <TextBlock.IsVisible>
                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                    <Binding
                                                    Converter="{x:Static ObjectConverters.IsNotNull}"
                                                    Path="MalformedMessage" />
                                                    <Binding Path="!$parent[views:ImportSessionsContentView].EnableMalformedMessageTap" />
                                                </MultiBinding>
                                            </TextBlock.IsVisible>
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  Date  -->
                                    <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Text="{Binding StartTime, StringFormat={}{0: yyyy-MM-dd HH:mm}}"
                                    TextAlignment="Right" />

                                    <!--  Duration  -->
                                    <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Text="{Binding Duration, StringFormat=duration: {0}}"
                                    TextAlignment="Right" />
                                </Grid>
                            </Expander.Header>
                            <Grid
                            Height="150"
                            HorizontalAlignment="Stretch"
                            ColumnDefinitions="auto *"
                            RowDefinitions="auto auto auto *">

                                <Label
                                Grid.Row="1"
                                Grid.Column="0"
                                VerticalAlignment="Center">
                                    Name:
                                </Label>
                                <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="2"
                                Text="{Binding Name}">
                                    <TextBox.IsEnabled>
                                        <Binding Path="!$parent[views:ImportSessionsContentView].((vm:ImportSessionsViewModel)DataContext).ImportSessionsCommand.IsRunning" />
                                    </TextBox.IsEnabled>
                                </TextBox>
                                <Label
                                Grid.Row="2"
                                Grid.Column="0"
                                VerticalAlignment="Center">
                                    Description:
                                </Label>
                                <TextBox
                                Grid.Row="2"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Margin="2"
                                VerticalAlignment="Stretch"
                                AcceptsReturn="True"
                                Text="{Binding Description}"
                                TextWrapping="Wrap">
                                    <TextBox.IsEnabled>
                                        <Binding Path="!$parent[views:ImportSessionsContentView].((vm:ImportSessionsViewModel)DataContext).ImportSessionsCommand.IsRunning" />
                                    </TextBox.IsEnabled>
                                </TextBox>
                            </Grid>
                        </Expander>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!--  Notifications  -->
        <v:NotificationsBar
        Grid.Row="2"
        Grid.Column="0"
        Grid.ColumnSpan="3"
        Margin="2,4"
        ZIndex="10" />

        <!--  Error messages  -->
        <v:ErrorMessagesBar
        Grid.Row="3"
        Grid.Column="0"
        Grid.ColumnSpan="3"
        Margin="2,4"
        ZIndex="10" />

        <ContentControl
        Grid.Row="4"
        Grid.Column="0"
        Grid.ColumnSpan="3"
        Content="{Binding $parent[views:ImportSessionsContentView].BottomContent}" />

        <!--  Busy overlay  -->
        <v:BusyOverlay
        Grid.Row="0"
        Grid.RowSpan="5"
        Grid.Column="0"
        Grid.ColumnSpan="3"
        BusyMessageFontWeight="Bold"
        IndicatorForeground="{DynamicResource SufniAccentColor}"
        Message="{Binding ImportProgressText}"
        MessageForeground="{DynamicResource SufniAccentColor}"
        MessageMargin="0,60,0,0"
        SecondaryMessage="Fetching sessions list"
        TintBackground="#0d0d0d"
        TintOpacity="0.7">
            <v:BusyOverlay.ShowTint>
                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                    <Binding Path="ImportSessionsCommand.IsRunning" />
                    <Binding Path="IsLoadingFiles" />
                </MultiBinding>
            </v:BusyOverlay.ShowTint>
            <v:BusyOverlay.IsActive>
                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                    <Binding Path="!TelemetryDataStores.Count" />
                    <Binding Path="ImportSessionsCommand.IsRunning" />
                    <Binding Path="IsLoadingFiles" />
                </MultiBinding>
            </v:BusyOverlay.IsActive>
            <v:BusyOverlay.ShowMessage>
                <Binding Path="ImportSessionsCommand.IsRunning" />
            </v:BusyOverlay.ShowMessage>
            <v:BusyOverlay.ShowSecondaryMessage>
                <Binding Path="IsLoadingFiles" />
            </v:BusyOverlay.ShowSecondaryMessage>
        </v:BusyOverlay>

    </Grid>
</UserControl>
