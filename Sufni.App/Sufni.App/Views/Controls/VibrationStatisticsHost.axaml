<UserControl
x:Name="Root"
x:Class="Sufni.App.Views.Controls.VibrationStatisticsHost"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:commonplots="clr-namespace:Sufni.App.Views.Plots"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:plots="clr-namespace:Sufni.App.DesktopViews.Plots"
d:DesignHeight="450"
d:DesignWidth="800"
mc:Ignorable="d">

    <controls:PlaceholderOverlayContainer
    Name="{Binding #Root.HostName}"
    PresentationState="{Binding #Root.PresentationState}">
        <controls:PlaceholderOverlayContainer.ReadyContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="{Binding #Root.PlotRowHeight}" />
                </Grid.RowDefinitions>

                <commonplots:VibrationSummaryView
                AnalysisRange="{Binding #Root.AnalysisRange}"
                ImuLocation="{Binding #Root.ImuLocation}"
                SuspensionType="{Binding #Root.SuspensionType}"
                Telemetry="{Binding #Root.Telemetry}" />

                <plots:SessionStatisticsPlotView
                AnalysisRange="{Binding #Root.AnalysisRange}"
                Grid.Row="1"
                ImuLocation="{Binding #Root.ImuLocation}"
                PlotKind="VibrationThirds"
                SuspensionType="{Binding #Root.SuspensionType}"
                Telemetry="{Binding #Root.Telemetry}" />
            </Grid>
        </controls:PlaceholderOverlayContainer.ReadyContent>
        <controls:PlaceholderOverlayContainer.PlaceholderContent>
            <controls:SurfacePlaceholderCard
            MinCardHeight="{Binding #Root.MinCardHeight}"
            Title="{Binding #Root.Title}" />
        </controls:PlaceholderOverlayContainer.PlaceholderContent>
    </controls:PlaceholderOverlayContainer>
</UserControl>
