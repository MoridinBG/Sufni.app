<UserControl
    x:Class="Sufni.App.Views.Controls.UndoDeleteButton"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sufni.App.ViewModels.ItemLists"
    d:DesignHeight="50"
    d:DesignWidth="500"
    x:DataType="vm:ItemListViewModelBase"
    IsVisible="{Binding IsUndoVisible}"
    mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="{StaticResource SufniAccentColor}" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <Button
            Name="DismissButton"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Classes="embedded"
            Command="{Binding FinalizeDeleteCommand}"
            CornerRadius="0" />
        <Label
            Height="39"
            Margin="5,0,5,5"
            Padding="10,0,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            VerticalContentAlignment="Center"
            Background="#f0f0f0"
            Content="{Binding PendingName, StringFormat='{}{0} deleted.'}"
            CornerRadius="2"
            Foreground="{StaticResource SufniRegion}"
            IsHitTestVisible="False" />
        <Button
            Name="UndoButton"
            Height="39"
            Margin="0,0,10,5"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            VerticalContentAlignment="Center"
            Classes="embedded"
            Command="{Binding UndoDeleteCommand}"
            Content="undo"
            Foreground="{StaticResource SufniAccentColor}" />
    </Panel>
</UserControl>
