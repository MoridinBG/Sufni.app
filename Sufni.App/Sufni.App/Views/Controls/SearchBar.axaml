<UserControl
x:Class="Sufni.App.Views.Controls.SearchBar"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vml="clr-namespace:Sufni.App.ViewModels.ItemLists"
d:DesignHeight="450"
d:DesignWidth="800"
x:DataType="vml:ItemListViewModelBase"
mc:Ignorable="d">

    <controls:SearchBarCore
    SearchBoxBackground="{DynamicResource SufniSearchBarSurface}"
    SearchBoxBorderThickness="{StaticResource SufniSearchBarBorderThickness}"
    SearchBoxCornerRadius="{StaticResource SufniSearchBarCornerRadius}"
    SearchRowHeight="{StaticResource SufniSearchBarHeightGridLength}"
    SyncIndicatorForeground="{DynamicResource SufniAccentSpinner}">
        <controls:SearchBarCore.CloseButtonVisible>
            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                <Binding Path="SearchBoxIsFocused" />
                <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="SearchText" />
            </MultiBinding>
        </controls:SearchBarCore.CloseButtonVisible>
    </controls:SearchBarCore>
</UserControl>
