<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Sufni.App.Views.Controls.SearchBarWithDateFilter"
    x:DataType="vml:ItemListViewModelBase"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:progRing="clr-namespace:AvaloniaProgressRing;assembly=AvaloniaProgressRing"
    xmlns:v="clr-namespace:Sufni.App.Views"
    xmlns:vm="clr-namespace:Sufni.App.ViewModels"
    xmlns:vml="clr-namespace:Sufni.App.ViewModels.ItemLists"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vml:ItemListViewModelBase />
    </Design.DataContext>

    <!--  Filter  -->
    <Grid
        ColumnDefinitions="*"
        Margin="20,0,20,20"
        RowDefinitions="39 auto">

        <!--  Search box  -->
        <TextBox
            BorderThickness="0"
            CornerRadius="5"
            Grid.Row="0"
            IsFocused="{Binding SearchBoxIsFocused, Mode=OneWayToSource}"
            Padding="35,0,0,0"
            Text="{Binding SearchText}"
            VerticalContentAlignment="Center"
            Watermark="Search ..." />

        <!--  Hamburger menu  -->
        <Button
            Classes="embedded"
            Command="{Binding $parent[v:MainPagesViewBase].((vm:MainPagesViewModel)DataContext).OpenMenuPaneCommand}"
            Grid.Row="0"
            HorizontalAlignment="Left"
            Width="32">
            <Image Margin="0,2,0,0" Source="{SvgImage /Assets/fa-bars.svg}" />
        </Button>

        <!--  Close search button  -->
        <Button
            Classes="embedded"
            Command="{Binding ClearSearchTextCommand}"
            Grid.Row="0"
            HorizontalAlignment="Right"
            Margin="0,0,5,0"
            Name="CloseButton"
            Width="30">
            <Image Source="{SvgImage /Assets/fa-xmark.svg}" />
            <Button.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="DateFilterVisible" />
                    <Binding Converter="{x:Static ObjectConverters.IsNull}" Path="DateFilterFrom" />
                    <Binding Converter="{x:Static ObjectConverters.IsNull}" Path="DateFilterTo" />
                </MultiBinding>
            </Button.IsVisible>
        </Button>

        <!--  Connection indicator  -->
        <Button
            Classes="embedded"
            HorizontalAlignment="Right"
            Margin="0,0,5,0">
            <Button.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="!#CloseButton.IsVisible" />
                    <Binding FallbackValue="{x:False}" Path="$parent[v:MainPagesViewBase].((vm:MainPagesViewModel)DataContext).PairingClientPage.IsPaired" />
                    <Binding Path="!$parent[v:MainPagesViewBase].((vm:MainPagesViewModel)DataContext).SyncInProgress" />
                </MultiBinding>
            </Button.IsVisible>
            <Image
                Opacity="0.5"
                Source="{SvgImage /Assets/fa-link_green.svg}"
                Width="20" />
        </Button>

        <!--  Synchronization indicator  -->
        <progRing:ProgressRing
            Foreground="{StaticResource SufniAccentColor}"
            Height="15"
            HorizontalAlignment="Right"
            Margin="0,0,10,0"
            VerticalAlignment="Center"
            Width="15">
            <progRing:ProgressRing.IsActive>
                <Binding Path="$parent[v:MainPagesViewBase].((vm:MainPagesViewModel)DataContext).SyncInProgress" />
            </progRing:ProgressRing.IsActive>
        </progRing:ProgressRing>

        <!--  Date pickers  -->
        <Border
            Background="{StaticResource SufniRegion}"
            Grid.Column="0"
            Grid.Row="1"
            IsVisible="{Binding DateFilterVisible}"
            Name="DatePickers">
            <Grid
                ColumnDefinitions="* auto *"
                Margin="1,0,1,0"
                RowDefinitions="auto">

                <!--  From  -->
                <CalendarDatePicker
                    DisplayDateEnd="{Binding DateFilterTo}"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Margin="0,5,5,5"
                    SelectedDate="{Binding DateFilterFrom}" />
                <Button
                    Classes="embedded"
                    Command="{Binding ClearDateFilterCommand}"
                    CommandParameter="from"
                    Grid.Column="0"
                    HorizontalAlignment="Right"
                    IsVisible="{Binding DateFilterFrom, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Margin="0,0,20,0"
                    Width="30">
                    <Image Source="{SvgImage /Assets/fa-xmark.svg}" />
                </Button>

                <!--  Arrow  -->
                <TextBlock
                    Grid.Column="1"
                    Text="→"
                    VerticalAlignment="Center" />

                <!--  To  -->
                <CalendarDatePicker
                    DisplayDateStart="{Binding DateFilterFrom}"
                    Grid.Column="2"
                    Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    Margin="5,5,0,5"
                    SelectedDate="{Binding DateFilterTo}" />
                <Button
                    Classes="embedded"
                    Command="{Binding ClearDateFilterCommand}"
                    CommandParameter="to"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    IsVisible="{Binding DateFilterTo, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Margin="0,0,20,0"
                    Width="30">
                    <Image Source="{SvgImage /Assets/fa-xmark.svg}" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
