<UserControl
x:Class="Sufni.App.Views.SensorConfigurations.LinearShockSensorConfigurationView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:sensorConfigurations="clr-namespace:Sufni.App.Views.SensorConfigurations"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.SensorConfigurations"
d:DesignHeight="450"
d:DesignWidth="800"
x:DataType="vm:LinearShockSensorConfigurationViewModel"
mc:Ignorable="d">

    <sensorConfigurations:LinearSensorConfigurationView DataContext="{Binding}" />
</UserControl>
