<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Sufni.App.Views.SensorConfigurations.RotationalShockSensorConfigurationView"
    x:DataType="vm:RotationalShockSensorConfigurationViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sufni.App.ViewModels.SensorConfigurations"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:RotationalShockSensorConfigurationViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="auto *" RowDefinitions="auto auto auto auto">

        <!--  Sensor joint  -->
        <TextBlock
            Grid.Column="0"
            Grid.Row="0"
            Margin="5"
            Text="Sensor position" />
        <ComboBox
            Grid.Column="1"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding JointsForSensor}"
            Margin="0,2,2,2"
            SelectedItem="{Binding SensorJoint}">

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!--  First adjacent joint  -->
        <TextBlock
            Grid.Column="0"
            Grid.Row="1"
            Margin="5"
            Text="Adjacent 1" />
        <ComboBox
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding JointsForAdjacent1}"
            Margin="0,2,2,2"
            SelectedItem="{Binding AdjacentJoint1}">

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!--  Second adjacent joint  -->
        <TextBlock
            Grid.Column="0"
            Grid.Row="2"
            Margin="5"
            Text="Adjacent 2" />
        <ComboBox
            Grid.Column="1"
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding JointsForAdjacent2}"
            Margin="0,2,2,2"
            SelectedItem="{Binding AdjacentJoint2}">

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
    </Grid>
</UserControl>
