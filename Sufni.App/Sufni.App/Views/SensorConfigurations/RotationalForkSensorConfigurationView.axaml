<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Sufni.App.Views.SensorConfigurations.RotationalForkSensorConfigurationView"
    x:DataType="vm:RotationalForkSensorConfigurationViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sufni.App.ViewModels.SensorConfigurations"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:RotationalForkSensorConfigurationViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="auto *" RowDefinitions="auto auto">
        <!--  Length  -->
        <Label
            Content="Maximum length: "
            Grid.Column="0"
            Grid.Row="0"
            VerticalAlignment="Center" />
        <NumericUpDown
            Grid.Column="1"
            Grid.Row="0"
            Increment="1"
            Margin="0,2,2,2"
            Maximum="500"
            Minimum="100"
            Value="{Binding MaxLength}" />

        <!--  Resolution  -->
        <Label
            Content="Arm length: "
            Grid.Column="0"
            Grid.Row="1"
            VerticalAlignment="Center" />
        <NumericUpDown
            Grid.Column="1"
            Grid.Row="1"
            Margin="0,2,2,2"
            Maximum="500"
            Minimum="50"
            Value="{Binding ArmLength}" />
    </Grid>
</UserControl>
