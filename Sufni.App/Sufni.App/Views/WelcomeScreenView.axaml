<UserControl
x:Class="Sufni.App.Views.WelcomeScreenView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vm="clr-namespace:Sufni.App.ViewModels"
d:DesignHeight="800"
d:DesignWidth="800"
x:DataType="vm:WelcomeScreenViewModel"
mc:Ignorable="d">

    <StackPanel
    HorizontalAlignment="Center"
    VerticalAlignment="Center">
        <TextBlock FontSize="36" Text="Sufni Suspension Telemetry" />
        <Border Height="100" />
        <Button
        Name="ImportSessionsButton"
        Width="200"
        Margin="30,0,0,0"
        Classes="embedded hyperlink"
        Command="{Binding ImportSessionCommand}"
        Content="Import sessions ..."
        FontSize="18" />
        <Button
        Name="AddBikeButton"
        Width="200"
        Margin="30,0,0,0"
        Classes="embedded hyperlink"
        Command="{Binding AddBikeCommand}"
        Content="Create bike ..."
        FontSize="18" />
        <Button
        Name="AddSetupButton"
        Width="200"
        Margin="30,0,0,0"
        Classes="embedded hyperlink"
        Command="{Binding AddSetupCommand}"
        Content="Create setup ..."
        FontSize="18" />
        <Button
        Name="OpenLogsFolderButton"
        Width="200"
        Margin="30,0,0,0"
        Classes="embedded hyperlink"
        Command="{Binding OpenLogsFolderCommand}"
        Content="Open logs folder ..."
        FontSize="18"
        IsVisible="{Binding IsDesktop}" />
    </StackPanel>

</UserControl>
