<UserControl
    d:DesignHeight="800"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Sufni.App.Views.WelcomeScreenView"
    x:DataType="vm:WelcomeScreenViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sufni.App.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:WelcomeScreenViewModel />
    </Design.DataContext>

    <StackPanel
        HorizontalAlignment="Center"
        Margin="0,-200,0,0"
        VerticalAlignment="Center">
        <TextBlock FontSize="36" Text="Sufni Suspension Telemetry" />
        <Border Height="100" />
        <Button
            Classes="embedded hyperlink"
            Command="{Binding ImportSessionCommand}"
            Content="Import sessions ..."
            FontSize="18"
            Margin="30,0,0,0"
            Width="200" />
        <Button
            Classes="embedded hyperlink"
            Command="{Binding AddBikeCommand}"
            Content="Create bike ..."
            FontSize="18"
            Margin="30,0,0,0"
            Width="200" />
        <Button
            Classes="embedded hyperlink"
            Command="{Binding AddSetupCommand}"
            Content="Create setup ..."
            FontSize="18"
            Margin="30,0,0,0"
            Width="200" />
    </StackPanel>

</UserControl>
