<UserControl
    x:Class="Sufni.App.DesktopViews.Editors.BikeEditorDesktopView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:v="using:Sufni.App.DesktopViews.Items"
    xmlns:vm="using:Sufni.App.ViewModels.Editors"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:BikeEditorViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:BikeEditorViewModel />
    </Design.DataContext>

    <!--  Ensure that the LeverageRatioPlotViews' LeverageRatioData property is set  -->
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <InvokeCommandAction Command="{Binding LoadedCommand}" />
        </EventTriggerBehavior>
        <EventTriggerBehavior EventName="Unloaded">
            <InvokeCommandAction Command="{Binding UnloadedCommand}" />
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <SplitView
        DisplayMode="Inline"
        IsPaneOpen="True"
        OpenPaneLength="400"
        PanePlacement="Right">

        <SplitView.Pane>
            <v:BikeImageControlsDesktopView />
        </SplitView.Pane>

        <!--  Bike image / linkage  -->
        <v:BikeImageDesktopView />

    </SplitView>

</UserControl>
