<UserControl
    Background="{StaticResource SufniRegion}"
    Focusable="True"
    d:DesignHeight="600"
    d:DesignWidth="500"
    mc:Ignorable="d"
    x:Class="Sufni.App.DesktopViews.Items.SetupDesktopView"
    x:DataType="vm:SetupViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:v="clr-namespace:Sufni.App.Views.Controls"
    xmlns:vm="clr-namespace:Sufni.App.ViewModels.Items"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:SetupViewModel />
    </Design.DataContext>

    <Grid
        ColumnDefinitions="auto *"
        HorizontalAlignment="Stretch"
        Margin="20,0,20,10"
        MinWidth="300"
        RowDefinitions="auto auto auto auto auto auto auto * auto 40 39"
        VerticalAlignment="Stretch">
        <!--  Name  -->
        <Label
            Content="Name: "
            Grid.Column="0"
            Grid.Row="0"
            VerticalAlignment="Center" />
        <TextBox
            Grid.Column="1"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            Margin="2"
            Text="{Binding Name}" />

        <!--  Board ID  -->
        <Label
            Content="Board ID: "
            Grid.Column="0"
            Grid.Row="1"
            VerticalAlignment="Center" />
        <TextBox
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            Margin="2"
            Text="{Binding BoardId}" />

        <!--  Bike  -->
        <Label
            Content="Bike: "
            Grid.Column="0"
            Grid.Row="2"
            VerticalAlignment="Center" />
        <ComboBox
            Grid.Column="1"
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding Bikes}"
            Margin="2"
            SelectedItem="{Binding SelectedBike}">

            <ComboBox.DataTemplates>
                <DataTemplate DataType="vm:BikeViewModel">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" />
                        <Button
                            Classes="embedded"
                            Command="{Binding OpenPageCommand}"
                            CommandParameter="{Binding}"
                            Padding="10,0,0,0">
                            <Image
                                Height="12"
                                Source="{SvgImage /Assets/fa-edit.svg}"
                                Width="12" />
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.DataTemplates>
        </ComboBox>

        <!--  Fork sensor type  -->
        <Label
            Content="Fork sensor type: "
            Grid.Column="0"
            Grid.Row="3"
            VerticalAlignment="Center" />
        <ComboBox
            Grid.Column="1"
            Grid.Row="3"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding ForkSensorTypes}"
            Margin="2"
            PlaceholderText=" -- not in use --"
            SelectedItem="{Binding ForkSensorType}" />

        <!--  Fork sensor configuration  -->
        <ContentControl
            Content="{Binding ForkSensorConfiguration}"
            Grid.Column="1"
            Grid.Row="4" />

        <!--  Shock sensor type  -->
        <Label
            Content="Shock sensor type: "
            Grid.Column="0"
            Grid.Row="5"
            VerticalAlignment="Center" />
        <ComboBox
            Grid.Column="1"
            Grid.Row="5"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding ShockSensorTypes}"
            Margin="2"
            PlaceholderText=" -- not in use --"
            SelectedItem="{Binding ShockSensorType}" />

        <!--  Shock sensor configuration  -->
        <ContentControl
            Content="{Binding ShockSensorConfiguration}"
            Grid.Column="1"
            Grid.Row="6" />

        <!--  Error messages for Setup instance  -->
        <v:ErrorMessagesBar
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="8"
            Margin="0,5,0,0" />

        <!--  Save and Reset buttons  -->
        <Grid
            ColumnDefinitions="* auto"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="10">
            <Button
                Command="{Binding SaveCommand}"
                Content="Save"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Margin="0,0,10,0"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Center" />

            <Button
                Command="{Binding ResetCommand}"
                Grid.Column="1"
                Height="39"
                HorizontalContentAlignment="Center"
                Margin="0,0,5,0"
                VerticalContentAlignment="Center"
                Width="39">
                <Image
                    Height="16"
                    Source="{SvgImage /Assets/fa-rotate-left.svg}"
                    Width="16" />
            </Button>
        </Grid>
    </Grid>
</UserControl>