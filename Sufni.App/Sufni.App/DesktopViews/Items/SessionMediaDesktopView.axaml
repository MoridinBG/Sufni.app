<UserControl
x:Class="Sufni.App.DesktopViews.Items.SessionMediaDesktopView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:v="clr-namespace:Sufni.App.Views"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.Editors"
d:DesignHeight="450"
d:DesignWidth="320"
x:Name="Root"
x:DataType="vm:ISessionMediaWorkspace"
mc:Ignorable="d">

    <Grid
    Width="{Binding MapVideoWidth, TargetNullValue=400}"
    RowDefinitions="auto auto *">
        <Grid.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="MapViewModel.SessionTrackPoints" />
                <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="VideoUrl" />
            </MultiBinding>
        </Grid.IsVisible>

        <Border
        Grid.Row="0"
        Background="DarkSlateBlue"
        IsVisible="{Binding VideoUrl, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <GridSplitter Grid.Row="1" ResizeDirection="Rows">
            <GridSplitter.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="MapViewModel.SessionTrackPoints" />
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="VideoUrl" />
                </MultiBinding>
            </GridSplitter.IsVisible>
        </GridSplitter>

        <v:MapView
        Grid.Row="2"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        DataContext="{Binding MapViewModel}"
        Timeline="{Binding DataContext.Timeline, ElementName=Root}"
        IsVisible="{Binding SessionTrackPoints, Converter={x:Static ObjectConverters.IsNotNull}}" />
    </Grid>
</UserControl>