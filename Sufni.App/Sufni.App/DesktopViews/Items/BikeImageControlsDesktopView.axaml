<UserControl
    x:Class="Sufni.App.DesktopViews.Items.BikeImageControlsDesktopView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Sufni.App.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:plots="clr-namespace:Sufni.App.Views.Plots"
    xmlns:v="using:Sufni.App.DesktopViews.Items"
    xmlns:vm="using:Sufni.App.ViewModels.Items"
    xmlns:vml="using:Sufni.App.ViewModels.LinkageParts"
    xmlns:globalization="clr-namespace:System.Globalization;assembly=System.Runtime"
    d:DesignHeight="600"
    d:DesignWidth="400"
    x:DataType="vm:BikeViewModel"
    Background="{StaticResource SufniRegion}"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:BikeViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="39" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <Grid
        Margin="10"
        ColumnDefinitions="auto *"
        RowDefinitions="auto auto auto auto auto auto auto auto auto auto auto * auto * auto auto auto auto auto auto">

        <!--  Name  -->
        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Margin="0,0,10,5"
            Text="Name" />
        <TextBox
            Grid.Row="0"
            Grid.Column="1"
            Margin="0,0,0,5"
            Text="{Binding Name}" />

        <!--  Head angle  -->
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,0,0,5"
            Text="Head angle (°)" />
        <NumericUpDown
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,0,0,5"
            Maximum="90"
            Minimum="0"
            Value="{Binding HeadAngle}" />

        <!--  Fork stroke  -->
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,0,0,5"
            Text="Fork stroke (mm)" />
        <NumericUpDown
            Grid.Row="2"
            Grid.Column="1"
            Margin="0,0,0,5"
            Maximum="300"
            Minimum="0"
            Value="{Binding ForksStroke}" />

        <!--  Shock stroke  -->
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            Margin="0,0,10,5"
            Text="Shock stroke (mm)" />
        <NumericUpDown
            Grid.Row="3"
            Grid.Column="1"
            Margin="0,0,0,5"
            Maximum="1000"
            Minimum="0"
            Value="{Binding ShockStroke}" />

        <!--  Chainstay  -->
        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            Margin="0,0,0,5"
            IsVisible="{Binding ShockStroke, Converter={x:Static ObjectConverters.IsNotNull}}"
            Text="Chainstay (mm)" />
        <NumericUpDown
            Grid.Row="4"
            Grid.Column="1"
            Margin="0,0,0,5"
            IsVisible="{Binding ShockStroke, Converter={x:Static ObjectConverters.IsNotNull}}"
            Maximum="1000"
            Minimum="0"
            Value="{Binding Chainstay}" />

        <!--  Front Wheel  -->
        <TextBlock
            Grid.Row="5"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,10,0,5"
            FontWeight="SemiBold"
            IsVisible="{Binding ShockStroke, Converter={x:Static ObjectConverters.IsNotNull}}"
            Text="Front Wheel" />
        <Grid
            Grid.Row="6"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,5"
            ColumnDefinitions="* * *"
            IsVisible="{Binding ShockStroke, Converter={x:Static ObjectConverters.IsNotNull}}">
            <ComboBox
                Grid.Column="0"
                Margin="0,0,5,0"
                ItemsSource="{Binding RimSizeOptions}"
                PlaceholderText="Rim"
                SelectedValue="{Binding FrontWheelRimSize}"
                SelectedValueBinding="{Binding Value, DataType=vm:BikeViewModel+RimSizeOption}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:BikeViewModel+RimSizeOption">
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <NumericUpDown
                Grid.Column="1"
                Margin="0,0,5,0"
                FormatString="0.00"
                Increment="0.05"
                Maximum="5"
                Minimum="1"
                Value="{Binding FrontWheelTireWidth}"
                Watermark="Width" />
            <NumericUpDown
                Grid.Column="2"
                FormatString="0.0"
                Increment="1"
                Maximum="1000"
                Minimum="400"
                Value="{Binding FrontWheelDiameter}"
                Watermark="Ø mm" />
        </Grid>

        <!--  Rear Wheel  -->
        <TextBlock
            Grid.Row="7"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,10,0,5"
            FontWeight="SemiBold"
            IsVisible="{Binding ShockStroke, Converter={x:Static ObjectConverters.IsNotNull}}"
            Text="Rear Wheel" />
        <Grid
            Grid.Row="8"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,5"
            ColumnDefinitions="* * *"
            IsVisible="{Binding ShockStroke, Converter={x:Static ObjectConverters.IsNotNull}}">
            <ComboBox
                Grid.Column="0"
                Margin="0,0,5,0"
                ItemsSource="{Binding RimSizeOptions}"
                PlaceholderText="Rim"
                SelectedValue="{Binding RearWheelRimSize}"
                SelectedValueBinding="{Binding Value, DataType=vm:BikeViewModel+RimSizeOption}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:BikeViewModel+RimSizeOption">
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <NumericUpDown
                Grid.Column="1"
                Margin="0,0,5,0"
                FormatString="0.00"
                Increment="0.05"
                Maximum="5"
                Minimum="1"
                Value="{Binding RearWheelTireWidth}"
                Watermark="Width" />
            <NumericUpDown
                Grid.Column="2"
                FormatString="0.0"
                Increment="1"
                Maximum="1000"
                Minimum="400"
                Value="{Binding RearWheelDiameter}"
                Watermark="Ø mm" />
        </Grid>

        <Grid
            Grid.Row="9"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,15"
            ColumnDefinitions="* auto">
            <Grid.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="ShockStroke" />
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Chainstay" />
                </MultiBinding>
            </Grid.IsVisible>

            <!--  Open bike picture  -->
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,5,0"
                HorizontalAlignment="Stretch"
                Command="{Binding OpenImageCommand}"
                Content="Open image ..." />

            <!--  Overlay  -->
            <CheckBox
                Grid.Row="0"
                Grid.Column="1"
                Content="Draw overlay"
                IsChecked="{Binding OverlayVisible}" />
        </Grid>

        <!--  List of Points  -->
        <TextBlock
            Grid.Row="10"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,5"
            Text="Points">
            <TextBlock.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Image" />
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="ShockStroke" />
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Chainstay" />
                </MultiBinding>
            </TextBlock.IsVisible>
        </TextBlock>
        <ScrollViewer
            Grid.Row="11"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="2,0,2,6">

            <DataGrid
                BeginningEdit="DataGrid_OnBeginningEdit"
                BorderBrush="Gray"
                BorderThickness="1"
                GridLinesVisibility="All"
                ItemsSource="{Binding JointViewModels}"
                SelectedItem="{Binding SelectedPoint}">

                <DataGrid.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Image" />
                        <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="ShockStroke" />
                        <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Chainstay" />
                    </MultiBinding>
                </DataGrid.IsVisible>

                <DataGrid.KeyBindings>
                    <KeyBinding Command="{Binding DeleteSelectedItemCommand}" Gesture="Delete" />
                </DataGrid.KeyBindings>

                <DataGrid.Columns>

                    <!--  Name  -->
                    <DataGridTextColumn
                        Width="1.5*"
                        Binding="{Binding Name}"
                        Header="Name"
                        IsReadOnly="False" />

                    <!--  Type  -->
                    <DataGridTemplateColumn
                        Width="1.5*"
                        Header="Type"
                        IsReadOnly="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vml:JointViewModel">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{Binding Type}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate DataType="vml:JointViewModel">
                                <ComboBox
                                    HorizontalAlignment="Stretch"
                                    IsDropDownOpen="True"
                                    ItemsSource="{Binding PointTypes}"
                                    SelectedItem="{Binding Type}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!--  X  -->
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding X, StringFormat={}{0:0.00}}"
                        Header="X (px)"
                        IsReadOnly="True" />

                    <!--  Y  -->
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Y, StringFormat={}{0:0.00}}"
                        Header="Y (px)"
                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>

        <!--  List of Links  -->
        <TextBlock
            Grid.Row="12"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,5"
            Text="Links">
            <TextBlock.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Image" />
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="ShockStroke" />
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Chainstay" />
                </MultiBinding>
            </TextBlock.IsVisible>
        </TextBlock>
        <ScrollViewer
            Grid.Row="13"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="2,0,2,5">

            <DataGrid
                BeginningEdit="DataGrid_OnBeginningEdit"
                BorderBrush="Gray"
                BorderThickness="1"
                GridLinesVisibility="All"
                ItemsSource="{Binding LinkViewModels}"
                SelectedItem="{Binding SelectedLink}">

                <DataGrid.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Image" />
                        <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="ShockStroke" />
                        <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Chainstay" />
                    </MultiBinding>
                </DataGrid.IsVisible>

                <DataGrid.KeyBindings>
                    <KeyBinding Command="{Binding DeleteSelectedItemCommand}" Gesture="Delete" />
                </DataGrid.KeyBindings>

                <DataGrid.Columns>

                    <!--  Point A  -->
                    <DataGridTemplateColumn
                        Width="*"
                        Header="Point A"
                        IsReadOnly="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vml:LinkViewModel">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{Binding A.Name}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate DataType="vml:LinkViewModel">
                                <ComboBox
                                    HorizontalAlignment="Stretch"
                                    IsDropDownOpen="True"
                                    ItemsSource="{Binding $parent[v:BikeImageControlsDesktopView].((vm:BikeViewModel)DataContext).JointViewModels}"
                                    SelectedItem="{Binding A}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!--  Point B  -->
                    <DataGridTemplateColumn
                        Width="*"
                        Header="Point B"
                        IsReadOnly="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vml:LinkViewModel">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{Binding B.Name}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate DataType="vml:LinkViewModel">
                                <ComboBox
                                    HorizontalAlignment="Stretch"
                                    IsDropDownOpen="True"
                                    ItemsSource="{Binding $parent[v:BikeImageControlsDesktopView].((vm:BikeViewModel)DataContext).JointViewModels}"
                                    SelectedItem="{Binding B}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!--  Length  -->
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Length, StringFormat={}{0:0.00}}"
                        Header="L (mm)"
                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
        <Button
            Grid.Row="14"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Command="{Binding CreateLinkCommand}"
            Content="Add new link">
            <Button.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Image" />
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="ShockStroke" />
                    <Binding Converter="{x:Static ObjectConverters.IsNotNull}" Path="Chainstay" />
                </MultiBinding>
            </Button.IsVisible>
        </Button>

        <!--  Leverage ratio plot  -->
        <plots:LeverageRatioPlotView
            Grid.Row="15"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Height="250"
            HorizontalAlignment="Stretch"
            IsHitTestVisible="False"
            LeverageRatioData="{Binding LeverageRatioData}" />

        <controls:ErrorMessagesBar
            Grid.Row="16"
            Grid.Column="0"
            Grid.ColumnSpan="2" />

        <!--  Import  -->
        <Button
            Grid.Row="17"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Command="{Binding ImportCommand}"
            Content="Import from JSON" />

        <!--  Export  -->
        <Button
            Grid.Row="18"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Command="{Binding ExportCommand}"
            Content="Export as JSON" />

        <Button
            Grid.Row="19"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Command="{Binding SaveCommand}"
            Content="Save" />
    </Grid>
</UserControl>
