<UserControl
    x:Class="Sufni.App.DesktopViews.Items.BikeDesktopView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Sufni.App.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
    xmlns:ia="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:paz="using:Avalonia.Controls.PanAndZoom"
    xmlns:v="using:Sufni.App.DesktopViews.Items"
    xmlns:vm="using:Sufni.App.ViewModels.Items"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:BikeViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:BikeViewModel />
    </Design.DataContext>

    <Grid
        MinWidth="300"
        Margin="20,0,20,10"
        HorizontalAlignment="Stretch"
        ColumnDefinitions="* 400"
        RowDefinitions="auto * auto auto">

        <!--  Name  -->
        <controls:EditableTitle
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="-5,0,0,10"
            HorizontalAlignment="Stretch" />

        <!-- Bike image / linkage -->
        <v:BikeImageDesktopView Grid.Row="1" Grid.Column="0" />

        <!-- Linkage parts -->
        <v:BikeImageControlsDesktopView Grid.Row="1" Grid.Column="1" />

        <!--  Error messages for Bike instance  -->
        <controls:ErrorMessagesBar
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,5,0,0" />

        <!--  Back, Save, Reset and Delete buttons  -->
        <controls:CommonButtonLine
            Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="2" />
    </Grid>
</UserControl>
