<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Sufni.App.DesktopViews.Items.BikeDesktopView"
    x:DataType="vm:BikeViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:v="using:Sufni.App.DesktopViews.Items"
    xmlns:vm="using:Sufni.App.ViewModels.Items"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:BikeViewModel />
    </Design.DataContext>

    <SplitView
        DisplayMode="Inline"
        IsPaneOpen="True"
        OpenPaneLength="400"
        PanePlacement="Right">

        <SplitView.Pane>
            <v:BikeImageControlsDesktopView />
        </SplitView.Pane>

        <!--  Bike image / linkage  -->
        <v:BikeImageDesktopView />
    </SplitView>

</UserControl>
