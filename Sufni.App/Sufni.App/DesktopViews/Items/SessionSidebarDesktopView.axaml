<UserControl
x:Class="Sufni.App.DesktopViews.Items.SessionSidebarDesktopView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vm="clr-namespace:Sufni.App.ViewModels.Editors"
d:DesignHeight="450"
d:DesignWidth="400"
x:DataType="vm:ISessionSidebarWorkspace"
mc:Ignorable="d">

    <Grid RowDefinitions="auto * auto">
        <Grid Grid.Row="0" Margin="14,10,10,10" ColumnDefinitions="auto *">
            <Label
            Grid.Column="0"
            VerticalAlignment="Center"
            Content="Name: " />
            <TextBox
            Name="NameTextBox"
            Grid.Column="1"
            Margin="2"
            HorizontalAlignment="Stretch"
            Text="{Binding Name}" />
        </Grid>

        <Grid
        Grid.Row="1"
        Margin="0,10,0,0"
        ColumnDefinitions="15 auto 10 * 6 * 15"
        RowDefinitions="auto auto auto auto auto auto *">

            <Grid.Styles>
                <Style Selector="NumericUpDown">
                    <Setter Property="Minimum" Value="0" />
                    <Setter Property="Increment" Value="1" />
                    <Setter Property="Margin" Value="2" />
                </Style>
            </Grid.Styles>

            <Label
            Grid.Row="0"
            Grid.Column="3"
            HorizontalAlignment="Center"
            Content="Front" />
            <Label
            Grid.Row="0"
            Grid.Column="5"
            HorizontalAlignment="Center"
            Content="Rear" />

            <Label
            Grid.Row="1"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="Spring:" />
            <TextBox
            Grid.Row="1"
            Grid.Column="3"
            Margin="2"
            VerticalContentAlignment="Center"
            Text="{Binding ForkSettings.SpringRate}" />
            <TextBox
            Grid.Row="1"
            Grid.Column="5"
            Margin="2"
            VerticalContentAlignment="Center"
            Text="{Binding ShockSettings.SpringRate}" />

            <Label
            Grid.Row="2"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="HSC:" />
            <NumericUpDown
            Grid.Row="2"
            Grid.Column="3"
            Value="{Binding ForkSettings.HighSpeedCompression}" />
            <NumericUpDown
            Grid.Row="2"
            Grid.Column="5"
            Value="{Binding ShockSettings.HighSpeedCompression}" />

            <Label
            Grid.Row="3"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="LSC:" />
            <NumericUpDown
            Grid.Row="3"
            Grid.Column="3"
            Value="{Binding ForkSettings.LowSpeedCompression}" />
            <NumericUpDown
            Grid.Row="3"
            Grid.Column="5"
            Value="{Binding ShockSettings.LowSpeedCompression}" />

            <Label
            Grid.Row="4"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="LSR:" />
            <NumericUpDown
            Grid.Row="4"
            Grid.Column="3"
            Value="{Binding ForkSettings.LowSpeedRebound}" />
            <NumericUpDown
            Grid.Row="4"
            Grid.Column="5"
            Value="{Binding ShockSettings.LowSpeedRebound}" />

            <Label
            Grid.Row="5"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="HSR:" />
            <NumericUpDown
            Grid.Row="5"
            Grid.Column="3"
            Value="{Binding ForkSettings.HighSpeedRebound}" />
            <NumericUpDown
            Grid.Row="5"
            Grid.Column="5"
            Value="{Binding ShockSettings.HighSpeedRebound}" />

            <TextBox
            Name="DescriptionTextBox"
            Grid.Row="6"
            Grid.Column="1"
            Grid.ColumnSpan="5"
            Margin="0,10,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            VerticalContentAlignment="Top"
            AcceptsReturn="True"
            Text="{Binding DescriptionText}"
            TextWrapping="Wrap" />
        </Grid>

        <Grid Grid.Row="2" Margin="14,10,10,10" ColumnDefinitions="* auto">
            <Button
            Name="SaveButton"
            Grid.Column="0"
            Margin="0,0,10,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Command="{Binding SaveCommand}"
            Content="Save" />

            <Button
            Name="ResetButton"
            Grid.Column="1"
            Width="39"
            Height="39"
            Margin="0,0,5,0"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Command="{Binding ResetCommand}">
                <Image
                Width="16"
                Height="16"
                Source="{SvgImage /Assets/fa-rotate-left.svg}" />
            </Button>
        </Grid>
    </Grid>
</UserControl>