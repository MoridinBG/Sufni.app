<UserControl
    x:Class="Sufni.App.DesktopViews.ItemLists.SessionListDesktopView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Sufni.App.DesktopViews.Controls"
    xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:v="clr-namespace:Sufni.App.Views"
    xmlns:vm="clr-namespace:Sufni.App.ViewModels"
    xmlns:vml="clr-namespace:Sufni.App.ViewModels.ItemLists"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vml:SessionListViewModel"
    Background="{StaticResource SufniRegion}"
    mc:Ignorable="d">

    <Grid ColumnDefinitions="* auto" RowDefinitions="auto * auto auto">

        <!--  Search bar  -->
        <controls:SearchBarWithDateFilter
            Grid.Row="0"
            Grid.Column="0"
            Margin="0,20,0,20" />

        <!--  Add button  -->
        <Button
            Grid.Row="0"
            Grid.Column="1"
            Width="20"
            Margin="10,25,10,0"
            VerticalAlignment="Top"
            Classes="embedded"
            Command="{Binding $parent[v:MainPagesViewBase].((vm:MainPagesViewModel)DataContext).OpenImportCommand}">
            <Image
                Width="18"
                Margin="0,0,30,0"
                Source="{SvgImage /Assets/fa-file-import.svg}" />
        </Button>

        <!--  List of Sessions  -->
        <ScrollViewer
            Name="Scroll"
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2">
            <ItemsRepeater ItemsSource="{Binding Items}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <c:DeletableListItemButton />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!--  Notifications  -->
        <controls:NotificationsBar
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="5,0"
            ZIndex="10" />

        <!--  Error messages  -->
        <controls:ErrorMessagesBar
            Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="5,0"
            ZIndex="10" />

        <!--  Undo last deleted  -->
        <controls:UndoDeleteButton
            Grid.Row="0"
            Grid.RowSpan="4"
            Grid.Column="0"
            Grid.ColumnSpan="2" />
    </Grid>
</UserControl>