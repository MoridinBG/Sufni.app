<UserControl
    Background="{StaticResource SufniRegion}"
    d:DesignHeight="600"
    d:DesignWidth="500"
    mc:Ignorable="d"
    x:Class="Sufni.App.DesktopViews.ItemLists.BikeListDesktopView"
    x:DataType="vml:BikeListViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:c="clr-namespace:Sufni.App.DesktopViews.Controls"
    xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vml="clr-namespace:Sufni.App.ViewModels.ItemLists"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vml:BikeListViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="* auto" RowDefinitions="auto * auto auto">

        <!--  Search bar  -->
        <controls:SearchBar
            Grid.Column="0"
            Grid.Row="0"
            Margin="0,20,0,20" />

        <!--  Add button  -->
        <Button
            Classes="embedded"
            Command="{Binding AddCommand}"
            Grid.Column="1"
            Grid.Row="0"
            Margin="10,25,10,0"
            VerticalAlignment="Top"
            Width="20">
            <Image
                Margin="0,0,0,0"
                Source="{SvgImage /Assets/fa-circle-plus.svg}"
                Width="18" />
        </Button>

        <!--  List of Bikes  -->
        <ScrollViewer
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="1"
            Name="Scroll">
            <ItemsRepeater ItemsSource="{Binding Items}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <c:DeletableListItemButton />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!--  Notifications  -->
        <controls:NotificationsBar
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="2"
            Margin="5,0"
            ZIndex="10" />

        <!--  Error messages  -->
        <controls:ErrorMessagesBar
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="3"
            Margin="5,0"
            ZIndex="10" />

        <!--  Undo last deleted  -->
        <controls:UndoDeleteButton
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="0"
            Grid.RowSpan="4" />
    </Grid>
</UserControl>