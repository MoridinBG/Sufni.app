<UserControl
    x:Class="Sufni.App.DesktopViews.ItemLists.PairedDeviceListDesktopView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Sufni.App.DesktopViews.Controls"
    xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vml="clr-namespace:Sufni.App.ViewModels.ItemLists"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vml:PairedDeviceListViewModel"
    Background="{StaticResource SufniRegion}"
    mc:Ignorable="d">

    <Design.DataContext>
        <vml:PairedDeviceListViewModel />
    </Design.DataContext>

    <Grid
        Background="{StaticResource SufniBackgroundDisabled}"
        ColumnDefinitions="*"
        RowDefinitions="40 * auto">

        <!--  Title  -->
        <TextBlock
            VerticalAlignment="Center"
            FontSize="16"
            FontWeight="Bold"
            Text="Paired devices"
            TextAlignment="Center" />

        <!--  List of Paired devices  -->
        <ScrollViewer Name="Scroll" Grid.Row="1">
            <ItemsRepeater ItemsSource="{Binding Items}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <c:PairedDeviceListItemButton />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!--  Undo last deleted  -->
        <controls:UndoDeleteButton
            Grid.Column="0"
            Grid.Row="0"
            Grid.RowSpan="2" />
    </Grid>
</UserControl>