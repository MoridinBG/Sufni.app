<UserControl
    x:Class="Sufni.App.DesktopViews.Controls.LiveDaqListItemButton"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:itemLists="clr-namespace:Sufni.App.DesktopViews.ItemLists"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vml="clr-namespace:Sufni.App.ViewModels.ItemLists"
    xmlns:vmr="clr-namespace:Sufni.App.ViewModels.Rows"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vmr:LiveDaqRowViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vmr:LiveDaqRowViewModel />
    </Design.DataContext>

    <StackPanel>
        <Button
            Padding="14,10"
            HorizontalAlignment="Stretch"
            Classes="item"
            Command="{Binding $parent[itemLists:LiveDaqListDesktopView].((vml:LiveDaqListViewModel)DataContext).RowSelectedCommand}"
            CommandParameter="{Binding}"
            CornerRadius="0">
            <Grid ColumnDefinitions="* auto" RowDefinitions="auto auto auto">
                <StackPanel Grid.Column="0" Spacing="3">
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Text="{Binding DisplayName}" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock
                            Opacity="0.7"
                            Text="{Binding SetupName}" />
                        <TextBlock
                            Opacity="0.7"
                            Text="{Binding BikeName}" />
                    </StackPanel>

                    <TextBlock
                        Opacity="0.6"
                        Text="{Binding Endpoint}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Spacing="6">
                    <Border
                        Padding="8,3"
                        Background="#1f6b3f"
                        CornerRadius="999"
                        IsVisible="{Binding IsOnline}">
                        <TextBlock
                            FontSize="11"
                            Foreground="White"
                            Text="online" />
                    </Border>

                    <Border
                        Padding="8,3"
                        Background="#6d6d6d"
                        CornerRadius="999"
                        IsVisible="{Binding !IsOnline}">
                        <TextBlock
                            FontSize="11"
                            Foreground="White"
                            Text="offline" />
                    </Border>

                    <TextBlock
                        HorizontalAlignment="Right"
                        Opacity="0.7"
                        Text="{Binding BoardId}" />
                </StackPanel>
            </Grid>
        </Button>

        <Separator
            Height="1"
            Margin="0"
            Background="{StaticResource SufniBackgroundDisabled}" />
    </StackPanel>
</UserControl>