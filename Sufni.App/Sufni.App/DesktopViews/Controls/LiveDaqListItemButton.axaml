<UserControl
x:Class="Sufni.App.DesktopViews.Controls.LiveDaqListItemButton"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:itemLists="clr-namespace:Sufni.App.DesktopViews.ItemLists"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vml="clr-namespace:Sufni.App.ViewModels.ItemLists"
xmlns:vmr="clr-namespace:Sufni.App.ViewModels.Rows"
d:DesignHeight="450"
d:DesignWidth="800"
x:DataType="vmr:LiveDaqRowViewModel"
mc:Ignorable="d">

    <StackPanel>
        <Button
        x:Name="OpenButton"
        Padding="14,10"
        HorizontalAlignment="Stretch"
        Classes="item"
        Command="{Binding $parent[itemLists:LiveDaqListDesktopView].((vml:LiveDaqListViewModel)DataContext).RowSelectedCommand}"
        CommandParameter="{Binding}"
        CornerRadius="0"
        IsEnabled="{Binding IsOnline}">
            <Grid ColumnDefinitions="* auto">
                <StackPanel Grid.Column="0" Spacing="3">
                    <TextBlock
                    x:Name="DisplayNameTextBlock"
                    FontSize="15"
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis"
                    Text="{Binding DisplayName}" />

                    <TextBlock
                    x:Name="SetupNameTextBlock"
                    Opacity="0.7"
                    TextTrimming="CharacterEllipsis"
                    IsVisible="{Binding SetupName, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Text="{Binding SetupName}" />

                    <TextBlock
                    x:Name="BikeNameTextBlock"
                    Opacity="0.7"
                    TextTrimming="CharacterEllipsis"
                    IsVisible="{Binding BikeName, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Text="{Binding BikeName}" />

                    <TextBlock
                    x:Name="BoardIdTextBlock"
                    Opacity="0.6"
                    TextTrimming="CharacterEllipsis"
                    IsVisible="{Binding ShowBoardId}"
                    Text="{Binding BoardId}" />

                    <TextBlock
                    x:Name="EndpointTextBlock"
                    Opacity="0.6"
                    TextTrimming="CharacterEllipsis"
                    IsVisible="{Binding ShowEndpoint}"
                    Text="{Binding Endpoint}" />
                </StackPanel>

                <StackPanel
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Right">
                    <Border
                    x:Name="OnlineBadge"
                    Padding="8,3"
                    Background="#1f6b3f"
                    CornerRadius="999"
                    IsVisible="{Binding IsOnline}">
                        <TextBlock
                        FontSize="11"
                        Foreground="White"
                        Text="online" />
                    </Border>

                    <Border
                    x:Name="OfflineBadge"
                    Padding="8,3"
                    Background="#6d6d6d"
                    CornerRadius="999"
                    IsVisible="{Binding !IsOnline}">
                        <TextBlock
                        FontSize="11"
                        Foreground="White"
                        Text="offline" />
                    </Border>
                </StackPanel>
            </Grid>
        </Button>

        <Separator
        Height="1"
        Margin="0"
        Background="{StaticResource SufniBackgroundDisabled}" />
    </StackPanel>
</UserControl>