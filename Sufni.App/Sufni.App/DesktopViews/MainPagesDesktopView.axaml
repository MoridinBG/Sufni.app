<UserControl
x:Class="Sufni.App.DesktopViews.MainPagesDesktopView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:controls="clr-namespace:Sufni.App.Views.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:converters="using:Avalonia.Data.Converters"
xmlns:theming="clr-namespace:Sufni.App.Theming"
xmlns:v="clr-namespace:Sufni.App.DesktopViews"
xmlns:vm="clr-namespace:Sufni.App.ViewModels"
d:DesignHeight="720"
d:DesignWidth="500"
x:DataType="vm:MainPagesViewModel"
mc:Ignorable="d">

    <UserControl.Resources>
        <v:ProgressToArcConverter x:Key="ProgressToArcConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!--  Tabs  -->
        <Style Selector="TabControl">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Height" Value="46" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource SufniTabSurfaceSelected}" />
        </Style>
        <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SufniTabSurfaceHover}" />
        </Style>
        <Style Selector="TabItem:pointerover:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SufniTabSurfaceSelected}" />
        </Style>
        <Style Selector="TabItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Height" Value="25" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>
        <Style Selector="TabItem:disabled /template/ Border">
            <Setter Property="Opacity" Value="{StaticResource SufniActionDisabledIconOpacity}" />
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Height" Value="{StaticResource SufniSelectionIndicatorLengthVertical}" />
            <Setter Property="Width" Value="{StaticResource SufniSelectionIndicatorThickness}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Background" Value="{DynamicResource SufniAccentIndicatorNavPipe}" />
        </Style>
    </UserControl.Styles>

    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="AttachedToVisualTree">
            <InvokeCommandAction Command="{Binding PairingServerViewModel.LoadedCommand}" />
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <Panel>

        <!--  Menu tab  -->
        <TabControl
        Name="PagesMenu"
        Margin="0,0,0,5"
        Background="{DynamicResource SufniNavRailBackground}"
        SelectedIndex="{Binding SelectedIndex}"
        TabStripPlacement="Left">
            <TabItem Name="SessionTabItem">
                <TabItem.Header>
                    <StackPanel>
                        <Image Width="16" Source="{SvgImage /Assets/fa-chart-line.svg}" />
                        <TextBlock
                        Margin="0,2,0,0"
                        Padding="0,0,4,0"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource SufniTabFontSizeNav}"
                        Text="Sessions" />
                    </StackPanel>
                </TabItem.Header>
                <ContentControl Content="{Binding SessionsPage}" />
            </TabItem>
            <TabItem Name="BikeSetupsTabItem">
                <TabItem.Header>
                    <StackPanel>
                        <Image Width="18" Source="{SvgImage /Assets/cog.svg}" />
                        <TextBlock
                        Padding="0,0,4,0"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource SufniTabFontSizeNav}"
                        Text="Setups" />
                    </StackPanel>
                </TabItem.Header>
                <ContentControl Content="{Binding SetupsPage}" />
            </TabItem>
            <TabItem Name="BikesTabItem">
                <TabItem.Header>
                    <StackPanel>
                        <Image Width="18" Source="{SvgImage /Assets/fa-person-mountainbiking.svg}" />
                        <TextBlock
                        Padding="0,0,4,0"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource SufniTabFontSizeNav}"
                        Text="Bikes" />
                    </StackPanel>
                </TabItem.Header>
                <ContentControl Content="{Binding BikesPage}" />
            </TabItem>
            <TabItem Name="LiveDaqsTabItem">
                <TabItem.Header>
                    <StackPanel>
                        <Image Width="18" Source="{SvgImage /Assets/fa-link.svg}" />
                        <TextBlock
                        Padding="0,0,4,0"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource SufniTabFontSizeNav}"
                        Text="Live" />
                    </StackPanel>
                </TabItem.Header>
                <ContentControl Content="{Binding LiveDaqsPage}" />
            </TabItem>
        </TabControl>

        <StackPanel Margin="0,0,0,20" VerticalAlignment="Bottom">

            <!--  Add setup / bike button  -->
            <Button Width="50" Classes="embedded">
                <Button.Styles>
                    <Style Selector="MenuItem">
                        <Setter Property="Foreground" Value="{DynamicResource SufniForeground}" />
                    </Style>
                    <Style Selector="MenuItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Foreground" Value="{DynamicResource SufniForeground}" />
                    </Style>
                </Button.Styles>

                <Button.Flyout>
                    <MenuFlyout Placement="Right" PlacementAnchor="Right">
                        <MenuItem Command="{Binding SetupsPage.AddCommand}" Header="setup" />
                        <MenuItem Command="{Binding BikesPage.AddCommand}" Header="bike" />
                    </MenuFlyout>
                </Button.Flyout>

                <Image
                Width="18"
                Margin="3,0,0,0"
                Source="{SvgImage /Assets/fa-circle-plus.svg}" />
            </Button>

            <!--  Import sessions button  -->
            <Button
            Width="50"
            Classes="embedded"
            Command="{Binding OpenImportCommand}">
                <Image Width="18" Source="{SvgImage /Assets/fa-file-import.svg}" />
            </Button>

            <!--  Import GPX button  -->
            <Button
            Width="50"
            Classes="embedded"
            Command="{Binding OpenGpsTracksCommand}">
                <Image Width="18" Source="{SvgImage /Assets/fa-map.svg}" />
            </Button>

            <!--  Paired devices button  -->
            <Button
            Name="PairedDevicesButton"
            Width="50"
            Classes="embedded"
            Command="{Binding OpenClosePairedDevicesListCommand}">
                <Panel>
                    <Image Width="18" Source="{SvgImage /Assets/fa-link.svg}">
                        <Image.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="!SyncInProgress" />
                                <Binding Path="IsPairedDevicesListOpen" />
                            </MultiBinding>
                        </Image.IsVisible>
                    </Image>
                    <controls:ActivityIndicator
                    Name="PairedDevicesSyncIndicator"
                    Width="18"
                    Height="18"
                    Foreground="{DynamicResource SufniAccentColor}">
                        <controls:ActivityIndicator.IsActive>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="SyncInProgress" />
                                <Binding Path="!IsPairedDevicesListOpen" />
                            </MultiBinding>
                        </controls:ActivityIndicator.IsActive>
                        <controls:ActivityIndicator.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="SyncInProgress" />
                                <Binding Path="!IsPairedDevicesListOpen" />
                            </MultiBinding>
                        </controls:ActivityIndicator.IsVisible>
                    </controls:ActivityIndicator>
                </Panel>
            </Button>

            <!--  Theme toggle button  -->
            <Button
            Name="ThemeToggleButton"
            Width="50"
            Classes="embedded"
            Command="{Binding ToggleThemeCommand}">
                <Panel>
                    <Image
                    Width="18"
                    IsVisible="{Binding NextThemeMode, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={x:Static theming:SufniThemeMode.Light}}"
                    Source="{SvgImage /Assets/fa-sun.svg}" />
                    <Image
                    Width="18"
                    IsVisible="{Binding NextThemeMode, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={x:Static theming:SufniThemeMode.Dark}}"
                    Source="{SvgImage /Assets/fa-moon.svg}" />
                    <Image
                    Width="18"
                    IsVisible="{Binding NextThemeMode, Converter={x:Static converters:ObjectConverters.Equal}, ConverterParameter={x:Static theming:SufniThemeMode.System}}"
                    Source="{SvgImage /Assets/fa-circle-half-stroke.svg}" />
                </Panel>
            </Button>
        </StackPanel>

        <!--  Paired devices list  -->
        <Grid
        Name="PairedDevicesPanel"
        Height="300"
        Margin="50,0,20,25"
        VerticalAlignment="Bottom"
        IsVisible="{Binding IsPairedDevicesListOpen}"
        Opacity="0.9">
            <ContentControl Content="{Binding PairedDevicesPage}" />
            <controls:BusyOverlay
            Name="DesktopSyncBusyOverlay"
            BusyMessageFontWeight="Bold"
            ConsumesInput="False"
            IndicatorForeground="{DynamicResource SufniAccentColor}"
            IsActive="{Binding SyncInProgress}"
            IsProgressIndeterminate="{Binding SyncProgressIsIndeterminate}"
            IsVisible="{Binding SyncInProgress}"
            Message="{Binding SyncProgressText}"
            MessageForeground="{DynamicResource SufniAccentColor}"
            ProgressValue="{Binding SyncProgressValue}"
            ShowProgress="{Binding SyncInProgress}"
            ShowTint="True"
            TintBackground="{DynamicResource SufniSelectionSurfaceSubtle}"
            TintOpacity="0.85"
            UseStackLayout="True" />
        </Grid>

        <!--  New pairing request  -->
        <Grid
        Name="PairingRequestPanel"
        Margin="50,0,20,25"
        VerticalAlignment="Bottom"
        Background="{DynamicResource SufniSelectionSurfaceSubtle}"
        ColumnDefinitions="* 35"
        IsVisible="{Binding !!PairingServerViewModel.PairingPin}"
        Opacity="0.9"
        RowDefinitions="auto 24">

            <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="10,10,10,10"
            FontSize="{StaticResource SufniFontSizeHeading}">
                <Run Text="Pairing request from " />
                <LineBreak />
                <Run FontWeight="Bold" Text="{Binding PairingServerViewModel.RequestingName}" />
            </TextBlock>

            <!--  PIN Display  -->
            <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Margin="10,0,10,10"
            VerticalAlignment="Center"
            FontSize="24"
            FontWeight="Bold"
            LetterSpacing="10"
            Text="{Binding PairingServerViewModel.PairingPin}" />

            <!--  Progress Ring  -->
            <Path
            Grid.Row="1"
            Grid.Column="1"
            Data="{Binding PairingServerViewModel.Remaining, Converter={StaticResource ProgressToArcConverter}}"
            Fill="{DynamicResource SufniAccentSpinner}"
            Stroke="{DynamicResource SufniAccentSpinner}"
            StrokeLineCap="Round" />
        </Grid>
    </Panel>
</UserControl>
